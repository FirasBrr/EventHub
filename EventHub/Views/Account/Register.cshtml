@model EventHub.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Create Account - EventHub";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .register-container {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .register-card {
        background: rgba(26, 26, 46, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        border: 1px solid rgba(0, 210, 255, 0.2);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
        transition: all 0.3s ease;
    }

        .register-card:hover {
            border-color: rgba(0, 210, 255, 0.5);
            box-shadow: 0 25px 50px rgba(0, 210, 255, 0.1);
        }

    .register-header {
        background: linear-gradient(135deg, #00d2ff 0%, #3a7bd5 100%);
        padding: 2rem;
        text-align: center;
        border-radius: 20px 20px 0 0;
    }

        .register-header h3 {
            margin: 0;
            font-weight: 700;
        }

    .register-body {
        padding: 2rem;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .input-group-text {
        background: rgba(26, 26, 46, 0.9);
        border: 1px solid rgba(0, 210, 255, 0.2);
        border-right: none;
        color: #00d2ff;
    }

    .form-control {
        background: rgba(26, 26, 46, 0.9);
        border: 1px solid rgba(0, 210, 255, 0.2);
        color: white;
        padding: 0.75rem 1rem;
    }

        .form-control:focus {
            background: rgba(26, 26, 46, 1);
            border-color: #00d2ff;
            box-shadow: 0 0 0 0.2rem rgba(0, 210, 255, 0.25);
            color: white;
        }

        .form-control::placeholder {
            color: #6c6c8a;
        }

    .btn-register-submit {
        background: linear-gradient(135deg, #00d2ff 0%, #3a7bd5 100%);
        color: white;
        padding: 0.75rem;
        font-weight: 600;
        border-radius: 10px;
        transition: all 0.3s ease;
        width: 100%;
        border: none;
    }

        .btn-register-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0, 210, 255, 0.4);
        }

    .login-link {
        text-align: center;
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

        .login-link a {
            color: #00d2ff;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
        }

            .login-link a:hover {
                color: #3a7bd5;
                text-decoration: underline;
            }

    .password-requirements {
        background: rgba(0, 210, 255, 0.05);
        border-radius: 10px;
        padding: 0.75rem;
        margin-top: 0.5rem;
    }

        .password-requirements small {
            color: #a0a0b0;
            font-size: 0.8rem;
        }

        .password-requirements i {
            color: #00d2ff;
            margin-right: 5px;
        }

    .validation-summary {
        background: rgba(255, 0, 0, 0.1);
        border-left: 4px solid #ff0000;
        padding: 1rem;
        border-radius: 10px;
        margin-bottom: 1.5rem;
    }

        .validation-summary ul {
            margin: 0;
            color: #ff6666;
        }

    .text-danger {
        color: #ff6666 !important;
        font-size: 0.8rem;
    }
</style>

<div class="container register-container">
    <div class="row justify-content-center w-100">
        <div class="col-md-8 col-lg-6">
            <div class="register-card">
                <div class="register-header">
                    <h3>
                        <i class="bi bi-person-plus-fill"></i> Create Account
                    </h3>
                    <p class="mb-0 mt-2">Join EventHub and discover amazing events</p>
                </div>

                <div class="register-body">
                    <form asp-action="Register" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="FirstName" class="form-label text-light mb-2">
                                        <i class="bi bi-person"></i> First Name
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="bi bi-person"></i>
                                        </span>
                                        <input asp-for="FirstName" class="form-control"
                                               placeholder="Enter your first name" />
                                    </div>
                                    <span asp-validation-for="FirstName" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="LastName" class="form-label text-light mb-2">
                                        <i class="bi bi-person"></i> Last Name
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="bi bi-person"></i>
                                        </span>
                                        <input asp-for="LastName" class="form-control"
                                               placeholder="Enter your last name" />
                                    </div>
                                    <span asp-validation-for="LastName" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label asp-for="Username" class="form-label text-light mb-2">
                                <i class="bi bi-person-badge"></i> Username
                            </label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-at"></i>
                                </span>
                                <input asp-for="Username" class="form-control"
                                       placeholder="Choose a username" />
                            </div>
                            <span asp-validation-for="Username" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Email" class="form-label text-light mb-2">
                                <i class="bi bi-envelope"></i> Email Address
                            </label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-envelope"></i>
                                </span>
                                <input asp-for="Email" class="form-control"
                                       placeholder="Enter your email address" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Password" class="form-label text-light mb-2">
                                <i class="bi bi-lock"></i> Password
                            </label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-key"></i>
                                </span>
                                <input asp-for="Password" class="form-control" type="password"
                                       id="Password" placeholder="Create a password" />
                                <button class="btn btn-outline-secondary" type="button"
                                        onclick="togglePassword('Password')"
                                        style="background: rgba(26, 26, 46, 0.9); border-color: rgba(0,210,255,0.2);">
                                    <i class="bi bi-eye" id="toggleIconPassword"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="text-danger"></span>

                            <div class="password-requirements">
                                <small>
                                    <i class="bi bi-info-circle"></i> Password must contain:
                                </small><br />
                                <small>
                                    <i class="bi bi-check-circle" id="lengthCheck"></i> At least 6 characters<br />
                                    <i class="bi bi-check-circle" id="upperCheck"></i> At least one uppercase letter<br />
                                    <i class="bi bi-check-circle" id="digitCheck"></i> At least one number
                                </small>
                            </div>
                        </div>

                        <div class="form-group">
                            <label asp-for="ConfirmPassword" class="form-label text-light mb-2">
                                <i class="bi bi-lock-fill"></i> Confirm Password
                            </label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-check-lg"></i>
                                </span>
                                <input asp-for="ConfirmPassword" class="form-control" type="password"
                                       id="ConfirmPassword" placeholder="Confirm your password" />
                                <button class="btn btn-outline-secondary" type="button"
                                        onclick="togglePassword('ConfirmPassword')"
                                        style="background: rgba(26, 26, 46, 0.9); border-color: rgba(0,210,255,0.2);">
                                    <i class="bi bi-eye" id="toggleIconConfirm"></i>
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-register-submit">
                            <i class="bi bi-person-plus"></i> Create Account
                        </button>

                        <div class="login-link">
                            <p class="mb-0">
                                Already have an account?
                                <a asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right"></i> Sign in here
                                </a>
                            </p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function togglePassword(fieldId) {
        const passwordField = document.querySelector(`#${fieldId}`);
        const toggleIcon = document.querySelector(`#toggleIcon${fieldId === 'Password' ? 'Password' : 'Confirm'}`);

        if (passwordField.type === 'password') {
            passwordField.type = 'text';
            toggleIcon.classList.remove('bi-eye');
            toggleIcon.classList.add('bi-eye-slash');
        } else {
            passwordField.type = 'password';
            toggleIcon.classList.remove('bi-eye-slash');
            toggleIcon.classList.add('bi-eye');
        }
    }

    // Real-time password validation
    const passwordInput = document.getElementById('Password');
    if (passwordInput) {
        passwordInput.addEventListener('input', function() {
            const password = this.value;

            // Length check
            const lengthCheck = document.getElementById('lengthCheck');
            if (password.length >= 6) {
                lengthCheck.classList.remove('bi-check-circle');
                lengthCheck.classList.add('bi-check-circle-fill');
                lengthCheck.style.color = '#00ff00';
            } else {
                lengthCheck.classList.remove('bi-check-circle-fill');
                lengthCheck.classList.add('bi-check-circle');
                lengthCheck.style.color = '#a0a0b0';
            }

            // Uppercase check
            const upperCheck = document.getElementById('upperCheck');
            if (/[A-Z]/.test(password)) {
                upperCheck.classList.remove('bi-check-circle');
                upperCheck.classList.add('bi-check-circle-fill');
                upperCheck.style.color = '#00ff00';
            } else {
                upperCheck.classList.remove('bi-check-circle-fill');
                upperCheck.classList.add('bi-check-circle');
                upperCheck.style.color = '#a0a0b0';
            }

            // Digit check
            const digitCheck = document.getElementById('digitCheck');
            if (/[0-9]/.test(password)) {
                digitCheck.classList.remove('bi-check-circle');
                digitCheck.classList.add('bi-check-circle-fill');
                digitCheck.style.color = '#00ff00';
            } else {
                digitCheck.classList.remove('bi-check-circle-fill');
                digitCheck.classList.add('bi-check-circle');
                digitCheck.style.color = '#a0a0b0';
            }
        });
    }
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}