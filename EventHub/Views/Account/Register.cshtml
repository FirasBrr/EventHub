@model EventHub.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Create Account - EventHub";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .register-container {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
    }

    .register-card {
        max-width: 560px;
        width: 100%;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 32px;
    }

    .register-header {
        text-align: center;
        margin-bottom: 28px;
    }

        .register-header h2 {
            font-size: 1.5rem;
            font-weight: 600;
            color: var(--text-hi);
            margin-bottom: 8px;
        }

        .register-header p {
            color: var(--text-lo);
            font-size: 0.85rem;
        }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group label {
            font-size: 0.8rem;
            font-weight: 500;
            color: var(--text-md);
            margin-bottom: 6px;
            display: block;
        }

    .input-wrapper {
        display: flex;
        align-items: center;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 10px;
        transition: all 0.2s;
    }

        .input-wrapper:focus-within {
            border-color: var(--accent-blue);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
        }

    .input-icon {
        padding: 0 12px;
        color: var(--text-lo);
        font-size: 0.9rem;
    }

    .input-wrapper input {
        flex: 1;
        padding: 11px 12px 11px 0;
        background: transparent;
        border: none;
        color: var(--text-hi);
        font-size: 0.9rem;
        outline: none;
    }

        .input-wrapper input::placeholder {
            color: var(--text-lo);
        }

    .toggle-password {
        background: transparent;
        border: none;
        padding: 0 12px;
        color: var(--text-lo);
        cursor: pointer;
    }

    .row {
        display: flex;
        gap: 16px;
        margin-bottom: 0;
    }

        .row .form-group {
            flex: 1;
            margin-bottom: 0;
        }

    .password-requirements {
        background: var(--bg);
        border-radius: 10px;
        padding: 12px;
        margin-top: 12px;
    }

    .requirements-title {
        font-size: 0.7rem;
        color: var(--text-lo);
        margin-bottom: 8px;
    }

    .requirement {
        font-size: 0.7rem;
        color: var(--text-lo);
        margin: 4px 0;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .requirement i {
            font-size: 0.65rem;
        }

        .requirement.valid i {
            color: #10b981;
        }

        .requirement.invalid i {
            color: var(--text-lo);
        }

    .btn-register {
        width: 100%;
        background: var(--accent-blue);
        color: white;
        border: none;
        padding: 12px;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        margin-top: 8px;
    }

        .btn-register:hover {
            background: #2563eb;
            transform: translateY(-1px);
        }

    .login-link {
        text-align: center;
        margin-top: 20px;
        padding-top: 20px;
        border-top: 1px solid var(--border);
    }

        .login-link a {
            color: var(--accent-blue);
            text-decoration: none;
            font-weight: 500;
            font-size: 0.85rem;
        }

            .login-link a:hover {
                text-decoration: underline;
            }

    .validation-summary {
        background: #fef2f2;
        border-radius: 10px;
        padding: 12px;
        margin-bottom: 20px;
        font-size: 0.8rem;
        color: #dc2626;
    }

    .text-danger {
        color: #dc2626 !important;
        font-size: 0.7rem;
        margin-top: 4px;
        display: block;
    }
</style>

<div class="register-container">
    <div class="register-card">
        <div class="register-header">
            <h2>Create an account</h2>
            <p>Join EventHub to discover amazing events</p>
        </div>

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="row">
                <div class="form-group">
                    <label asp-for="FirstName">First name</label>
                    <div class="input-wrapper">
                        <span class="input-icon"><i class="bi bi-person"></i></span>
                        <input asp-for="FirstName" placeholder="First name" />
                    </div>
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="LastName">Last name</label>
                    <div class="input-wrapper">
                        <span class="input-icon"><i class="bi bi-person"></i></span>
                        <input asp-for="LastName" placeholder="Last name" />
                    </div>
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Username">Username</label>
                <div class="input-wrapper">
                    <span class="input-icon"><i class="bi bi-at"></i></span>
                    <input asp-for="Username" placeholder="Choose a username" />
                </div>
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email">Email address</label>
                <div class="input-wrapper">
                    <span class="input-icon"><i class="bi bi-envelope"></i></span>
                    <input asp-for="Email" type="email" placeholder="your@email.com" />
                </div>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password">Password</label>
                <div class="input-wrapper">
                    <span class="input-icon"><i class="bi bi-key"></i></span>
                    <input asp-for="Password" type="password" id="Password" placeholder="Create a password" />
                    <button type="button" class="toggle-password" onclick="togglePassword('Password')">
                        <i class="bi bi-eye" id="toggleIconPassword"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>

                <div class="password-requirements">
                    <div class="requirements-title">Password must contain:</div>
                    <div class="requirement" id="lengthReq">
                        <i class="bi bi-circle"></i> At least 6 characters
                    </div>
                    <div class="requirement" id="upperReq">
                        <i class="bi bi-circle"></i> One uppercase letter
                    </div>
                    <div class="requirement" id="digitReq">
                        <i class="bi bi-circle"></i> One number
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword">Confirm password</label>
                <div class="input-wrapper">
                    <span class="input-icon"><i class="bi bi-check-lg"></i></span>
                    <input asp-for="ConfirmPassword" type="password" id="ConfirmPassword" placeholder="Confirm your password" />
                    <button type="button" class="toggle-password" onclick="togglePassword('ConfirmPassword')">
                        <i class="bi bi-eye" id="toggleIconConfirm"></i>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-register">
                <i class="bi bi-person-plus"></i> Create account
            </button>

            <div class="login-link">
                <a asp-action="Login">
                    Already have an account? Sign in
                </a>
            </div>
        </form>
    </div>
</div>

<script>
    function togglePassword(fieldId) {
        const passwordField = document.querySelector(`#${fieldId}`);
        const toggleIcon = document.querySelector(`#toggleIcon${fieldId === 'Password' ? 'Password' : 'Confirm'}`);

        if (passwordField.type === 'password') {
            passwordField.type = 'text';
            toggleIcon.classList.remove('bi-eye');
            toggleIcon.classList.add('bi-eye-slash');
        } else {
            passwordField.type = 'password';
            toggleIcon.classList.remove('bi-eye-slash');
            toggleIcon.classList.add('bi-eye');
        }
    }

    // Real-time password validation
    const passwordInput = document.getElementById('Password');
    if (passwordInput) {
        passwordInput.addEventListener('input', function() {
            const password = this.value;

            // Length check
            const lengthReq = document.getElementById('lengthReq');
            if (password.length >= 6) {
                lengthReq.classList.add('valid');
                lengthReq.classList.remove('invalid');
                lengthReq.querySelector('i').className = 'bi bi-check-circle-fill';
                lengthReq.querySelector('i').style.color = '#10b981';
            } else {
                lengthReq.classList.add('invalid');
                lengthReq.classList.remove('valid');
                lengthReq.querySelector('i').className = 'bi bi-circle';
                lengthReq.querySelector('i').style.color = '';
            }

            // Uppercase check
            const upperReq = document.getElementById('upperReq');
            if (/[A-Z]/.test(password)) {
                upperReq.classList.add('valid');
                upperReq.classList.remove('invalid');
                upperReq.querySelector('i').className = 'bi bi-check-circle-fill';
                upperReq.querySelector('i').style.color = '#10b981';
            } else {
                upperReq.classList.add('invalid');
                upperReq.classList.remove('valid');
                upperReq.querySelector('i').className = 'bi bi-circle';
                upperReq.querySelector('i').style.color = '';
            }

            // Digit check
            const digitReq = document.getElementById('digitReq');
            if (/[0-9]/.test(password)) {
                digitReq.classList.add('valid');
                digitReq.classList.remove('invalid');
                digitReq.querySelector('i').className = 'bi bi-check-circle-fill';
                digitReq.querySelector('i').style.color = '#10b981';
            } else {
                digitReq.classList.add('invalid');
                digitReq.classList.remove('valid');
                digitReq.querySelector('i').className = 'bi bi-circle';
                digitReq.querySelector('i').style.color = '';
            }
        });
    }
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}