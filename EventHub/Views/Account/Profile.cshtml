@model EventHub.ViewModels.ProfileViewModel
@using Microsoft.AspNetCore.Identity

@{
    ViewData["Title"] = "My Profile - EventHub";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .profile-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 40px 20px;
    }

    /* Profile Header */
    .profile-header {
        text-align: center;
        margin-bottom: 32px;
    }

    .avatar {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, var(--accent-blue) 0%, #2563eb 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
    }

        .avatar i {
            font-size: 2.5rem;
            color: white;
        }

    .profile-header h1 {
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--text-hi);
        margin-bottom: 4px;
    }

    .profile-header .email {
        color: var(--text-lo);
        font-size: 0.85rem;
        margin-bottom: 8px;
    }

    .profile-header .member-since {
        color: var(--text-lo);
        font-size: 0.75rem;
    }

    /* Stats Grid */
    .stats-grid {
        display: flex;
        gap: 16px;
        margin-bottom: 32px;
        flex-wrap: wrap;
    }

    .stat-card {
        flex: 1;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 20px;
        text-align: center;
        min-width: 120px;
    }

    .stat-number {
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--accent-blue);
        margin-bottom: 4px;
    }

    .stat-label {
        font-size: 0.75rem;
        color: var(--text-lo);
    }

    /* Cards */
    .profile-card, .password-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 24px;
        margin-bottom: 24px;
    }

    .card-title {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-hi);
        margin-bottom: 20px;
        padding-bottom: 12px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .card-title i {
            color: var(--accent-blue);
        }

    /* Form Elements */
    .form-group {
        margin-bottom: 20px;
    }

        .form-group label {
            font-size: 0.8rem;
            font-weight: 500;
            color: var(--text-md);
            margin-bottom: 6px;
            display: block;
        }

    .input-wrapper {
        display: flex;
        align-items: center;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 10px;
        transition: all 0.2s;
    }

        .input-wrapper:focus-within {
            border-color: var(--accent-blue);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
        }

    .input-icon {
        padding: 0 12px;
        color: var(--text-lo);
    }

    .input-wrapper input {
        flex: 1;
        padding: 11px 12px 11px 0;
        background: transparent;
        border: none;
        color: var(--text-hi);
        font-size: 0.9rem;
        outline: none;
    }

        .input-wrapper input::placeholder {
            color: var(--text-lo);
        }

    .row {
        display: flex;
        gap: 16px;
        margin-bottom: 0;
    }

        .row .form-group {
            flex: 1;
            margin-bottom: 0;
        }

    /* Buttons */
    .btn-save {
        background: var(--accent-blue);
        color: white;
        border: none;
        padding: 10px 24px;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-save:hover {
            background: #2563eb;
            transform: translateY(-1px);
        }

    .btn-change-password {
        background: transparent;
        border: 1px solid var(--border);
        color: var(--text-md);
        padding: 10px 24px;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-change-password:hover {
            border-color: var(--accent-blue);
            color: var(--accent-blue);
            background: rgba(59, 130, 246, 0.05);
        }

    /* Password Section */
    .password-note {
        background: var(--bg);
        border-radius: 8px;
        padding: 10px 12px;
        margin-top: 12px;
        font-size: 0.7rem;
        color: var(--text-lo);
    }

    .text-danger {
        color: #dc2626 !important;
        font-size: 0.7rem;
        margin-top: 4px;
        display: block;
    }

    hr {
        margin: 20px 0;
        border-color: var(--border);
    }
</style>

<div class="profile-container">
    <!-- Profile Header -->
    <div class="profile-header">
        <div class="avatar">
            <i class="bi bi-person-fill"></i>
        </div>
        <h1>@Model.FirstName @Model.LastName</h1>
        <div class="email">@Model.Email</div>
        <div class="member-since">
            <i class="bi bi-calendar3"></i> Member since @Model.CreatedAt.ToString("MMMM yyyy")
        </div>
    </div>

    <!-- Statistics -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-number">@Model.TotalEventsAttended</div>
            <div class="stat-label">Events attended</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">@Model.UpcomingEventsCount</div>
            <div class="stat-label">Upcoming</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">@((DateTime.Now - Model.CreatedAt).Days)</div>
            <div class="stat-label">Days with us</div>
        </div>
    </div>

    <!-- Edit Profile Section -->
    <div class="profile-card">
        <div class="card-title">
            <i class="bi bi-pencil-square"></i> Edit profile
        </div>

        <form asp-action="Profile" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 16px;"></div>

            <div class="row">
                <div class="form-group">
                    <label asp-for="FirstName">First name</label>
                    <div class="input-wrapper">
                        <span class="input-icon"><i class="bi bi-person"></i></span>
                        <input asp-for="FirstName" />
                    </div>
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="LastName">Last name</label>
                    <div class="input-wrapper">
                        <span class="input-icon"><i class="bi bi-person"></i></span>
                        <input asp-for="LastName" />
                    </div>
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Username">Username</label>
                <div class="input-wrapper">
                    <span class="input-icon"><i class="bi bi-at"></i></span>
                    <input asp-for="Username" />
                </div>
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email">Email address</label>
                <div class="input-wrapper">
                    <span class="input-icon"><i class="bi bi-envelope"></i></span>
                    <input asp-for="Email" type="email" />
                </div>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-save">
                <i class="bi bi-check-lg"></i> Save changes
            </button>
        </form>
    </div>

    <!-- Change Password Section -->
    <div class="password-card">
        <div class="card-title">
            <i class="bi bi-key"></i> Change password
        </div>

        <form asp-action="ChangePassword" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 16px;"></div>

            <div class="form-group">
                <label for="CurrentPassword">Current password</label>
                <div class="input-wrapper">
                    <span class="input-icon"><i class="bi bi-shield-lock"></i></span>
                    <input type="password" name="CurrentPassword" id="CurrentPassword" required />
                </div>
            </div>

            <div class="form-group">
                <label for="NewPassword">New password</label>
                <div class="input-wrapper">
                    <span class="input-icon"><i class="bi bi-lock"></i></span>
                    <input type="password" name="NewPassword" id="NewPassword" required />
                </div>
            </div>

            <div class="form-group">
                <label for="ConfirmPassword">Confirm new password</label>
                <div class="input-wrapper">
                    <span class="input-icon"><i class="bi bi-check-lg"></i></span>
                    <input type="password" name="ConfirmPassword" id="ConfirmPassword" required />
                </div>
            </div>

            <div class="password-note">
                <i class="bi bi-info-circle"></i> Password must be at least 6 characters with an uppercase letter and a number.
            </div>

            <button type="submit" class="btn-change-password" style="margin-top: 16px;">
                <i class="bi bi-arrow-repeat"></i> Update password
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}