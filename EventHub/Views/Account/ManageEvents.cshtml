@model IEnumerable<EventHub.Models.Event>

@{
    ViewData["Title"] = "Manage Events - Admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .page-header {
        margin-bottom: 32px;
    }

        .page-header h1 {
            font-size: 1.5rem;
            font-weight: 600;
            color: var(--text-hi);
            display: flex;
            align-items: center;
            gap: 10px;
        }

    .search-bar {
        display: flex;
        gap: 12px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .search-input {
        flex: 1;
        min-width: 200px;
        padding: 10px 16px;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 10px;
        color: var(--text-hi);
        font-size: 0.85rem;
    }

        .search-input:focus {
            outline: none;
            border-color: var(--accent-blue);
        }

    .btn-search {
        background: var(--accent-blue);
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 10px;
        cursor: pointer;
    }

        .btn-search:hover {
            background: #2563eb;
        }

    .status-filter {
        padding: 10px 16px;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 10px;
        color: var(--text-hi);
        cursor: pointer;
    }

    .events-table {
        width: 100%;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow-x: auto;
    }

        .events-table table {
            width: 100%;
            border-collapse: collapse;
            min-width: 700px;
        }

        .events-table th {
            text-align: left;
            padding: 14px 16px;
            background: var(--bg);
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--text-lo);
            border-bottom: 1px solid var(--border);
        }

        .events-table td {
            padding: 14px 16px;
            font-size: 0.85rem;
            color: var(--text-md);
            border-bottom: 1px solid var(--border);
        }

        .events-table tr:hover {
            background: rgba(59, 130, 246, 0.04);
        }

    .status-badge {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 500;
    }

    .status-active {
        background: rgba(16, 185, 129, 0.1);
        color: #10b981;
    }

    .status-inactive {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
    }

    .capacity-bar {
        width: 80px;
        background: var(--bg);
        border-radius: 10px;
        height: 6px;
        overflow: hidden;
    }

    .capacity-fill {
        background: var(--accent-blue);
        height: 100%;
        border-radius: 10px;
    }

    .action-buttons {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .btn-icon {
        background: transparent;
        border: 1px solid var(--border);
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 0.7rem;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

        .btn-icon:hover {
            background: rgba(59, 130, 246, 0.05);
        }

    .btn-view {
        color: var(--accent-blue);
    }

    .btn-edit {
        color: #f59e0b;
    }

    .btn-toggle {
        color: #10b981;
    }

    .empty-state {
        text-align: center;
        padding: 60px;
        color: var(--text-lo);
    }
</style>

<div class="container">
    <div class="page-header">
        <h1>
            <i class="bi bi-calendar3"></i> Manage Events
        </h1>
    </div>

    <form method="get" class="search-bar">
        <input type="text" name="search" class="search-input" placeholder="Search by event name or location..." value="@ViewBag.SearchTerm" />
        <select name="status" class="status-filter">
            <option value="">All Status</option>
            <option value="active" selected="@(ViewBag.Status == "active")">Active</option>
            <option value="inactive" selected="@(ViewBag.Status == "inactive")">Inactive</option>
        </select>
        <button type="submit" class="btn-search">
            <i class="bi bi-search"></i> Search
        </button>
        <a href="/Admin/ManageEvents" class="btn-search" style="background: #64748b; text-decoration: none;">Clear</a>
        <a href="/Event/Create" class="btn-search" style="background: #10b981; text-decoration: none;">
            <i class="bi bi-plus-circle"></i> Create Event
        </a>
    </form>

    <div class="events-table">
        <table>
            <thead>
                <tr>
                    <th>Event</th>
                    <th>Date</th>
                    <th>Location</th>
                    <th>Registrations</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var fillPercentage = item.Capacity > 0 ? (item.Registrations?.Count ?? 0) * 100 / item.Capacity : 0;
                    <tr>
                        <td>
                            <div style="font-weight: 500; color: var(--text-hi);">@item.Name</div>
                            <div style="font-size: 0.7rem; color: var(--text-lo);">@item.Category</div>
                        </td>
                        <td style="white-space: nowrap;">
                            <div>@item.DateTime.ToString("MMM dd, yyyy")</div>
                            <div style="font-size: 0.7rem;">@item.DateTime.ToString("h:mm tt")</div>
                        </td>
                        <td>@item.Location</td>
                        <td>
                            <div>@(item.Registrations?.Count ?? 0) / @item.Capacity</div>
                            <div class="capacity-bar">
                                <div class="capacity-fill" style="width: @fillPercentage%"></div>
                            </div>
                        </td>
                        <td>
                            <span class="status-badge @(item.IsActive ? "status-active" : "status-inactive")">
                                @(item.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td>
                            <div class="action-buttons">
                                <a asp-controller="Event" asp-action="Details" asp-route-id="@item.Id" class="btn-icon btn-view">
                                    <i class="bi bi-eye"></i> View
                                </a>
                                <a asp-controller="Event" asp-action="Edit" asp-route-id="@item.Id" class="btn-icon btn-edit">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <form asp-action="ToggleEventStatus" asp-route-id="@item.Id" method="post" style="display: inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-icon btn-toggle">
                                        <i class="bi bi-@(item.IsActive ? "pause-circle" : "play-circle")"></i>
                                        @(item.IsActive ? "Disable" : "Enable")
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="bi bi-calendar-x" style="font-size: 2rem;"></i>
                <p>No events found</p>
                <a href="/Event/Create" class="btn-search" style="display: inline-block; margin-top: 10px;">Create your first event</a>
            </div>
        }
    </div>
</div>