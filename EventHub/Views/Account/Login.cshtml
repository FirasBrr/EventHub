@model EventHub.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Sign In - EventHub";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .login-container {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .login-card {
        background: rgba(26, 26, 46, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        border: 1px solid rgba(0, 210, 255, 0.2);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
        transition: all 0.3s ease;
    }

        .login-card:hover {
            border-color: rgba(0, 210, 255, 0.5);
            box-shadow: 0 25px 50px rgba(0, 210, 255, 0.1);
        }

    .login-header {
        background: linear-gradient(135deg, #00d2ff 0%, #3a7bd5 100%);
        padding: 2rem;
        text-align: center;
        border-radius: 20px 20px 0 0;
    }

        .login-header h3 {
            margin: 0;
            font-weight: 700;
        }

    .login-body {
        padding: 2rem;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .input-group-text {
        background: rgba(26, 26, 46, 0.9);
        border: 1px solid rgba(0, 210, 255, 0.2);
        border-right: none;
        color: #00d2ff;
    }

    .form-control {
        background: rgba(26, 26, 46, 0.9);
        border: 1px solid rgba(0, 210, 255, 0.2);
        color: white;
        padding: 0.75rem 1rem;
    }

        .form-control:focus {
            background: rgba(26, 26, 46, 1);
            border-color: #00d2ff;
            box-shadow: 0 0 0 0.2rem rgba(0, 210, 255, 0.25);
            color: white;
        }

        .form-control::placeholder {
            color: #6c6c8a;
        }

    .btn-login-submit {
        background: linear-gradient(135deg, #00d2ff 0%, #3a7bd5 100%);
        color: white;
        padding: 0.75rem;
        font-weight: 600;
        border-radius: 10px;
        transition: all 0.3s ease;
        width: 100%;
        border: none;
    }

        .btn-login-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0, 210, 255, 0.4);
        }

    .checkbox-label {
        color: #a0a0b0;
        cursor: pointer;
    }

    .form-check-input {
        background-color: rgba(26, 26, 46, 0.9);
        border-color: rgba(0, 210, 255, 0.3);
    }

        .form-check-input:checked {
            background-color: #00d2ff;
            border-color: #00d2ff;
        }

    .register-link {
        text-align: center;
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

        .register-link a {
            color: #00d2ff;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
        }

            .register-link a:hover {
                color: #3a7bd5;
                text-decoration: underline;
            }

    .demo-credentials {
        background: rgba(0, 210, 255, 0.1);
        border-left: 4px solid #00d2ff;
        border-radius: 10px;
        padding: 1rem;
        margin-top: 1.5rem;
    }

        .demo-credentials small {
            color: #a0a0b0;
        }

        .demo-credentials strong {
            color: #00d2ff;
        }

    .validation-summary {
        background: rgba(255, 0, 0, 0.1);
        border-left: 4px solid #ff0000;
        padding: 1rem;
        border-radius: 10px;
        margin-bottom: 1.5rem;
    }

        .validation-summary ul {
            margin: 0;
            color: #ff6666;
        }
</style>

<div class="container login-container">
    <div class="row justify-content-center w-100">
        <div class="col-md-6 col-lg-5">
            <div class="login-card">
                <div class="login-header">
                    <h3>
                        <i class="bi bi-box-arrow-in-right"></i> Welcome Back!
                    </h3>
                    <p class="mb-0 mt-2">Sign in to continue to EventHub</p>
                </div>

                <div class="login-body">
                    <form asp-action="Login" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div>

                        <div class="form-group">
                            <label asp-for="UsernameOrEmail" class="form-label text-light mb-2">
                                <i class="bi bi-person-circle"></i> Username or Email
                            </label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-envelope"></i>
                                </span>
                                <input asp-for="UsernameOrEmail" class="form-control"
                                       placeholder="Enter your username or email" autofocus />
                            </div>
                            <span asp-validation-for="UsernameOrEmail" class="text-danger small"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Password" class="form-label text-light mb-2">
                                <i class="bi bi-lock"></i> Password
                            </label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-key"></i>
                                </span>
                                <input asp-for="Password" class="form-control" type="password"
                                       placeholder="Enter your password" />
                                <button class="btn btn-outline-secondary" type="button"
                                        onclick="togglePassword()" style="background: rgba(26, 26, 46, 0.9); border-color: rgba(0,210,255,0.2);">
                                    <i class="bi bi-eye" id="toggleIcon"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="form-group form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label checkbox-label">
                                <i class="bi bi-check2-circle"></i> Remember me
                            </label>
                        </div>

                        <button type="submit" class="btn btn-login-submit">
                            <i class="bi bi-box-arrow-in-right"></i> Sign In
                        </button>

                        <div class="register-link">
                            <p class="mb-0">
                                Don't have an account?
                                <a asp-action="Register">
                                    <i class="bi bi-person-plus"></i> Create an account
                                </a>
                            </p>
                        </div>

                        <div class="demo-credentials">
                            <small>
                                <i class="bi bi-info-circle"></i> <strong>Demo Credentials:</strong><br />
                                <i class="bi bi-envelope"></i> Email: admin@eventhub.com<br />
                                <i class="bi bi-key"></i> Password: Admin@123
                            </small>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function togglePassword() {
        const passwordField = document.querySelector('#Password');
        const toggleIcon = document.querySelector('#toggleIcon');

        if (passwordField.type === 'password') {
            passwordField.type = 'text';
            toggleIcon.classList.remove('bi-eye');
            toggleIcon.classList.add('bi-eye-slash');
        } else {
            passwordField.type = 'password';
            toggleIcon.classList.remove('bi-eye-slash');
            toggleIcon.classList.add('bi-eye');
        }
    }
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}