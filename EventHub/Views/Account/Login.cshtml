@model EventHub.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Sign In - EventHub";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .login-container {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
    }

    .login-card {
        max-width: 420px;
        width: 100%;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 32px;
    }

    .login-header {
        text-align: center;
        margin-bottom: 28px;
    }

        .login-header h2 {
            font-size: 1.5rem;
            font-weight: 600;
            color: var(--text-hi);
            margin-bottom: 8px;
        }

        .login-header p {
            color: var(--text-lo);
            font-size: 0.85rem;
        }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group label {
            font-size: 0.8rem;
            font-weight: 500;
            color: var(--text-md);
            margin-bottom: 6px;
            display: block;
        }

    .input-wrapper {
        display: flex;
        align-items: center;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 10px;
        transition: all 0.2s;
    }

        .input-wrapper:focus-within {
            border-color: var(--accent-blue);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
        }

    .input-icon {
        padding: 0 12px;
        color: var(--text-lo);
        font-size: 0.9rem;
    }

    .input-wrapper input {
        flex: 1;
        padding: 11px 12px 11px 0;
        background: transparent;
        border: none;
        color: var(--text-hi);
        font-size: 0.9rem;
        outline: none;
    }

        .input-wrapper input::placeholder {
            color: var(--text-lo);
        }

    .toggle-password {
        background: transparent;
        border: none;
        padding: 0 12px;
        color: var(--text-lo);
        cursor: pointer;
    }

    .checkbox-group {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 24px;
    }

        .checkbox-group input {
            width: 16px;
            height: 16px;
            accent-color: var(--accent-blue);
            margin: 0;
        }

        .checkbox-group label {
            font-size: 0.8rem;
            color: var(--text-md);
            margin: 0;
        }

    .btn-login {
        width: 100%;
        background: var(--accent-blue);
        color: white;
        border: none;
        padding: 12px;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-login:hover {
            background: #2563eb;
            transform: translateY(-1px);
        }

    .register-link {
        text-align: center;
        margin-top: 20px;
        padding-top: 20px;
        border-top: 1px solid var(--border);
    }

        .register-link a {
            color: var(--accent-blue);
            text-decoration: none;
            font-weight: 500;
            font-size: 0.85rem;
        }

            .register-link a:hover {
                text-decoration: underline;
            }

    .demo-box {
        background: var(--bg);
        border-radius: 12px;
        padding: 16px;
        margin-top: 24px;
    }

        .demo-box p {
            font-size: 0.75rem;
            color: var(--text-lo);
            margin: 0;
        }

        .demo-box strong {
            color: var(--accent-blue);
        }

    .validation-summary {
        background: #fef2f2;
        border-radius: 10px;
        padding: 12px;
        margin-bottom: 20px;
        font-size: 0.8rem;
        color: #dc2626;
    }

    .text-danger {
        color: #dc2626 !important;
        font-size: 0.7rem;
        margin-top: 4px;
        display: block;
    }

    hr {
        margin: 20px 0;
        border-color: var(--border);
    }
</style>

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <h2>Welcome back</h2>
            <p>Sign in to your account</p>
        </div>

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="UsernameOrEmail">Username or email</label>
                <div class="input-wrapper">
                    <span class="input-icon"><i class="bi bi-envelope"></i></span>
                    <input asp-for="UsernameOrEmail" placeholder="Enter your username or email" autofocus />
                </div>
                <span asp-validation-for="UsernameOrEmail" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password">Password</label>
                <div class="input-wrapper">
                    <span class="input-icon"><i class="bi bi-key"></i></span>
                    <input asp-for="Password" type="password" id="password" placeholder="Enter your password" />
                    <button type="button" class="toggle-password" onclick="togglePassword()">
                        <i class="bi bi-eye" id="toggleIcon"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="checkbox-group">
                <input asp-for="RememberMe" id="rememberMe" />
                <label asp-for="RememberMe">Remember me</label>
            </div>

            <button type="submit" class="btn-login">
                <i class="bi bi-box-arrow-in-right"></i> Sign in
            </button>

            <div class="register-link">
                <a asp-action="Register">
                    <i class="bi bi-person-plus"></i> Create an account
                </a>
            </div>

            <div class="demo-box">
                <p>
                    <i class="bi bi-info-circle"></i> <strong>Demo credentials</strong><br />
                    Email: <strong>admin@eventhub.com</strong><br />
                    Password: <strong>Admin@123</strong>
                </p>
            </div>
        </form>
    </div>
</div>

<script>
    function togglePassword() {
        const passwordField = document.getElementById('password');
        const toggleIcon = document.getElementById('toggleIcon');

        if (passwordField.type === 'password') {
            passwordField.type = 'text';
            toggleIcon.classList.remove('bi-eye');
            toggleIcon.classList.add('bi-eye-slash');
        } else {
            passwordField.type = 'password';
            toggleIcon.classList.remove('bi-eye-slash');
            toggleIcon.classList.add('bi-eye');
        }
    }
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}