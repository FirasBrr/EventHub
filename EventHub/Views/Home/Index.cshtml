                        <i class="bi bi-mic display-1 text-primary"></i>
                    </div>
                    <h5 class="fw-bold">Conferences</h5>
                    <p class="text-muted small">Tech, Business & More</p>
                    <span class="badge bg-primary">24 Events</span>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="category-card text-center p-4 bg-white rounded-4 shadow-sm hover-lift">
                    <div class="category-icon mb-3">
                        <i class="bi bi-music-note display-1 text-success"></i>
                    </div>
                    <h5 class="fw-bold">Music</h5>
                    <p class="text-muted small">Concerts & Festivals</p>
                    <span class="badge bg-success">18 Events</span>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="category-card text-center p-4 bg-white rounded-4 shadow-sm hover-lift">
                    <div class="category-icon mb-3">
                        <i class="bi bi-briefcase display-1 text-info"></i>
                    </div>
                    <h5 class="fw-bold">Workshops</h5>
                    <p class="text-muted small">Learn & Grow</p>
                    <span class="badge bg-info">32 Events</span>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="category-card text-center p-4 bg-white rounded-4 shadow-sm hover-lift">
