@{
    ViewData["Title"] = "EventHub - Discover Amazing Events";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Dark Theme Styles for Home Page */
    .hero-section {
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, #0f0c29 0%, #1a1a2e 50%, #16213e 100%);
        min-height: 85vh;
    }

    .btn-custom-primary {
        background: linear-gradient(135deg, #00d2ff 0%, #3a7bd5 100%);
        color: white;
        border: none;
        transition: all 0.3s ease;
    }

        .btn-custom-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(0, 210, 255, 0.3);
            color: white;
        }

    .btn-custom-outline {
        background: transparent;
        border: 2px solid #00d2ff;
        color: #00d2ff;
        transition: all 0.3s ease;
    }

        .btn-custom-outline:hover {
            background: rgba(0, 210, 255, 0.1);
            transform: translateY(-2px);
            color: #00d2ff;
        }

    .stat-box {
        text-align: center;
        border-right: 1px solid rgba(0, 210, 255, 0.3);
    }

        .stat-box:last-child {
            border-right: none;
        }

    .search-card {
        background: rgba(26, 26, 46, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        border: 1px solid rgba(0, 210, 255, 0.2);
        box-shadow: 0 20px 40px rgba(0,0,0,0.3);
    }

    .event-card {
        background: rgba(26, 26, 46, 0.95);
        backdrop-filter: blur(10px);
        transition: all 0.3s ease;
        overflow: hidden;
        border-radius: 15px;
        border: 1px solid rgba(0, 210, 255, 0.1);
    }

        .event-card:hover {
            transform: translateY(-10px);
            border-color: rgba(0, 210, 255, 0.5);
            box-shadow: 0 20px 40px rgba(0,0,0,0.3) !important;
        }

    .event-meta i {
        color: #00d2ff;
    }

    .price-tag {
        font-size: 1.3rem;
        font-weight: bold;
        background: linear-gradient(135deg, #00d2ff 0%, #3a7bd5 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .category-card {
        background: rgba(26, 26, 46, 0.95);
        backdrop-filter: blur(10px);
        transition: all 0.3s ease;
        cursor: pointer;
        border-radius: 15px;
        border: 1px solid rgba(0, 210, 255, 0.1);
    }

        .category-card:hover {
            transform: translateY(-8px);
            border-color: rgba(0, 210, 255, 0.5);
            box-shadow: 0 15px 30px rgba(0,0,0,0.2);
        }

    .step-number {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, #00d2ff 0%, #3a7bd5 100%);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        font-weight: bold;
        margin: 0 auto 20px;
        box-shadow: 0 10px 20px rgba(0, 210, 255, 0.3);
    }

    .testimonial-card {
        background: rgba(26, 26, 46, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        border: 1px solid rgba(0, 210, 255, 0.1);
        transition: all 0.3s ease;
    }

        .testimonial-card:hover {
            transform: translateY(-5px);
            border-color: rgba(0, 210, 255, 0.3);
        }

    .divider {
        width: 80px;
        height: 4px;
        background: linear-gradient(135deg, #00d2ff 0%, #3a7bd5 100%);
        border-radius: 2px;
        margin: 20px auto;
    }

    .newsletter-box {
        background: linear-gradient(135deg, #00d2ff 0%, #3a7bd5 100%);
        border-radius: 20px;
    }

    .btn-explore {
        background: linear-gradient(135deg, #00d2ff 0%, #3a7bd5 100%);
        color: white;
        padding: 12px 35px;
        border-radius: 50px;
        transition: all 0.3s ease;
        border: none;
    }

        .btn-explore:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(0, 210, 255, 0.4);
            color: white;
        }

    .rating-stars i {
        color: #FFD700;
        margin-right: 2px;
    }

    .animate-on-scroll {
        opacity: 0;
        transform: translateY(30px);
        transition: all 0.6s ease;
    }

        .animate-on-scroll.animated {
            opacity: 1;
            transform: translateY(0);
        }

    @@media (max-width: 768px) {
        .hero-section {
            min-height: 70vh;
        }

        .stat-box {
            border-right: none;
        }
    }
</style>

<!-- Hero Section -->
<section class="hero-section position-relative text-white">
    <div class="container h-100">
        <div class="row h-100 align-items-center" style="min-height: 85vh;">
            <div class="col-lg-7">
                <h1 class="display-3 fw-bold mb-4 animate__animated animate__fadeInUp">
                    Find Your Next<br />
                    <span style="background: linear-gradient(135deg, #00d2ff 0%, #3a7bd5 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Amazing Experience</span>
                </h1>
                <p class="lead mb-4 animate__animated animate__fadeInUp animate__delay-1s">
                    Discover exciting events, connect with people, and create unforgettable memories.
                    From concerts to conferences, find what makes you happy.
                </p>

                <div class="d-flex gap-3 flex-wrap animate__animated animate__fadeInUp animate__delay-2s">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a href="/Event" class="btn btn-custom-primary btn-lg px-5 py-3 fw-bold">
                            <i class="bi bi-calendar-event"></i> Browse Events
                        </a>
                        @if (User.IsInRole("Admin"))
                        {
                            <a href="/Event/Create" class="btn btn-custom-outline btn-lg px-5 py-3">
                                <i class="bi bi-plus-circle"></i> Create Event
                            </a>
                        }
                    }
                    else
                    {
                        <a href="/Account/Register" class="btn btn-custom-primary btn-lg px-5 py-3 fw-bold">
                            <i class="bi bi-person-plus"></i> Get Started Free
                            <i class="bi bi-arrow-right"></i>
                        </a>
                        <a href="/Account/Login" class="btn btn-custom-outline btn-lg px-5 py-3">
                            <i class="bi bi-box-arrow-in-right"></i> Sign In
                        </a>
                    }
                </div>

                <div class="row mt-5 g-4 animate__animated animate__fadeInUp animate__delay-3s">
                    <div class="col-4">
                        <div class="stat-box">
                            <h3 class="display-6 fw-bold mb-0">500+</h3>
                            <p class="mb-0">Events Hosted</p>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="stat-box">
                            <h3 class="display-6 fw-bold mb-0">10K+</h3>
                            <p class="mb-0">Happy Attendees</p>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="stat-box">
                            <h3 class="display-6 fw-bold mb-0">50+</h3>
                            <p class="mb-0">Cities</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-5 d-none d-lg-block animate__animated animate__fadeInRight">
                <div class="hero-image text-center">
                    <img src="https://cdn-icons-png.flaticon.com/512/10405/10405481.png" alt="Events" class="img-fluid" style="filter: drop-shadow(0 20px 30px rgba(0,0,0,0.3)); max-height: 400px;">
                </div>
            </div>
        </div>
    </div>
    <div class="wave-bottom">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320">
            <path fill="#0f0c29" fill-opacity="1" d="M0,96L48,112C96,128,192,160,288,160C384,160,480,128,576,122.7C672,117,768,139,864,154.7C960,171,1056,181,1152,165.3C1248,149,1344,107,1392,85.3L1440,64L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
        </svg>
    </div>
</section>

<!-- Search Section -->
<section class="container position-relative" style="margin-top: -50px; z-index: 2;">
    <div class="search-card p-4">
        <h3 class="text-center mb-4" style="background: linear-gradient(135deg, #00d2ff 0%, #3a7bd5 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
            <i class="bi bi-search"></i> Find Your Perfect Event
        </h3>
        <form action="/Event" method="get" class="row g-3">
            <div class="col-md-5">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0" style="border-color: rgba(0,210,255,0.2); color: #00d2ff;">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text" name="searchTerm" class="form-control border-start-0"
                           placeholder="Search events, categories, locations...">
                </div>
            </div>
            <div class="col-md-3">
                <select name="category" class="form-select">
                    <option value="">All Categories</option>
                    <option>Conference</option>
                    <option>Workshop</option>
                    <option>Music</option>
                    <option>Networking</option>
                    <option>Sports</option>
                </select>
            </div>
            <div class="col-md-2">
                <input type="date" name="date" class="form-control" placeholder="Date">
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-explore w-100">
                    <i class="bi bi-search"></i> Search
                </button>
            </div>
        </form>
    </div>
</section>

<!-- Categories Section -->
<section class="categories-section py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold text-white">Browse by Category</h2>
            <p class="lead text-muted">Find events that match your interests</p>
            <div class="divider"></div>
        </div>

        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="category-card text-center p-4 animate-on-scroll">
                    <div class="category-icon mb-3">
                        <i class="bi bi-mic display-1" style="color: #00d2ff;"></i>
                    </div>
                    <h5 class="fw-bold text-white">Conferences</h5>
                    <p class="text-muted small">Tech, Business & More</p>
                    <span class="badge" style="background: linear-gradient(135deg, #00d2ff 0%, #3a7bd5 100%);">24 Events</span>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="category-card text-center p-4 animate-on-scroll">
                    <div class="category-icon mb-3">
                        <i class="bi bi-music-note display-1" style="color: #00d2ff;"></i>
                    </div>
                    <h5 class="fw-bold text-white">Music</h5>
                    <p class="text-muted small">Concerts & Festivals</p>
                    <span class="badge" style="background: linear-gradient(135deg, #00d2ff 0%, #3a7bd5 100%);">18 Events</span>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="category-card text-center p-4 animate-on-scroll">
                    <div class="category-icon mb-3">
                        <i class="bi bi-briefcase display-1" style="color: #00d2ff;"></i>
                    </div>
                    <h5 class="fw-bold text-white">Workshops</h5>
                    <p class="text-muted small">Learn & Grow</p>
                    <span class="badge" style="background: linear-gradient(135deg, #00d2ff 0%, #3a7bd5 100%);">32 Events</span>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="category-card text-center p-4 animate-on-scroll">
                    <div class="category-icon mb-3">
                        <i class="bi bi-people display-1" style="color: #00d2ff;"></i>
                    </div>
                    <h5 class="fw-bold text-white">Networking</h5>
                    <p class="text-muted small">Meet & Connect</p>
                    <span class="badge" style="background: linear-gradient(135deg, #00d2ff 0%, #3a7bd5 100%);">15 Events</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- How It Works -->
<section class="how-it-works py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold text-white">How EventHub Works</h2>
            <p class="lead text-muted">Simple steps to start your event journey</p>
            <div class="divider"></div>
        </div>

        <div class="row g-4">
            <div class="col-md-4 text-center animate-on-scroll">
                <div class="step-number">1</div>
                <i class="bi bi-person-plus display-3" style="color: #00d2ff;"></i>
                <h5 class="fw-bold text-white mt-3">Create Account</h5>
                <p class="text-muted">Sign up for free and join our community</p>
            </div>
            <div class="col-md-4 text-center animate-on-scroll">
                <div class="step-number">2</div>
                <i class="bi bi-search display-3" style="color: #00d2ff;"></i>
                <h5 class="fw-bold text-white mt-3">Discover Events</h5>
                <p class="text-muted">Browse events matching your interests</p>
            </div>
            <div class="col-md-4 text-center animate-on-scroll">
                <div class="step-number">3</div>
                <i class="bi bi-ticket-perforated display-3" style="color: #00d2ff;"></i>
                <h5 class="fw-bold text-white mt-3">Register & Attend</h5>
                <p class="text-muted">Book your spot and enjoy the experience</p>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="newsletter-section py-5">
    <div class="container">
        <div class="newsletter-box p-5 text-center text-white">
            <h3 class="display-6 fw-bold mb-3">Ready to Start Your Journey?</h3>
            <p class="lead mb-4">Join EventHub today and discover amazing events near you</p>
            @if (!User.Identity.IsAuthenticated)
            {
                <a href="/Account/Register" class="btn btn-light btn-lg px-5" style="color: #1a1a2e; font-weight: bold;">
                    Get Started Now
                    <i class="bi bi-arrow-right"></i>
                </a>
            }
            else
            {
                <a href="/Event" class="btn btn-light btn-lg px-5" style="color: #1a1a2e; font-weight: bold;">
                    Browse Events
                    <i class="bi bi-arrow-right"></i>
                </a>
            }
        </div>
    </div>
</section>

<script src="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.js"></script>
<script>
    // Scroll animation
    const observerOptions = {
        threshold: 0.1,
        rootMargin: "0px 0px -50px 0px"
    };

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('animated');
                observer.unobserve(entry.target);
            }
        });
    }, observerOptions);

    document.querySelectorAll('.animate-on-scroll').forEach(el => {
        observer.observe(el);
    });
</script>