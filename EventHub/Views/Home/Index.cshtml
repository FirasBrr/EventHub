@{
    ViewData["Title"] = "EventHub - Discover Amazing Events";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero Section with Background -->
<section class="hero-section position-relative text-white" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 80vh;">
    <div class="container h-100">
        <div class="row h-100 align-items-center">
            <div class="col-lg-6 animate__animated animate__fadeInLeft">
                <h1 class="display-3 fw-bold mb-4">
                    Discover Amazing <br />
                    <span class="text-warning">Events Near You</span>
                </h1>
                <p class="lead mb-4">
                    Join thousands of people discovering exciting events, workshops, concerts,
                    and networking opportunities. Your next great experience starts here.
                </p>
                <div class="d-flex gap-3">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a href="/Event" class="btn btn-light btn-lg px-5 py-3 fw-bold">
                            <i class="bi bi-calendar-event"></i> Browse Events
                        </a>
                        @if (User.IsInRole("Admin"))
                        {
                            <a href="/Event/Create" class="btn btn-outline-light btn-lg px-5 py-3">
                                <i class="bi bi-plus-circle"></i> Create Event
                            </a>
                        }
                    }
                    else
                    {
                        <a href="/Account/Register" class="btn btn-light btn-lg px-5 py-3 fw-bold">
                            Get Started Free
                            <i class="bi bi-arrow-right"></i>
                        </a>
                        <a href="/Account/Login" class="btn btn-outline-light btn-lg px-5 py-3">
                            Sign In
                        </a>
                    }
                </div>

                <!-- Stats -->
                <div class="row mt-5 g-4">
                    <div class="col-4">
                        <div class="stat-box">
                            <h3 class="display-6 fw-bold mb-0">500+</h3>
                            <p class="mb-0">Events Hosted</p>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="stat-box">
                            <h3 class="display-6 fw-bold mb-0">10K+</h3>
                            <p class="mb-0">Happy Attendees</p>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="stat-box">
                            <h3 class="display-6 fw-bold mb-0">50+</h3>
                            <p class="mb-0">Cities</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 d-none d-lg-block animate__animated animate__fadeInRight">
                <div class="hero-image text-center">
                    <img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png" alt="Events" class="img-fluid" style="filter: drop-shadow(0 20px 30px rgba(0,0,0,0.2));">
                </div>
            </div>
        </div>
    </div>
    <div class="wave-bottom">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320">
            <path fill="#ffffff" fill-opacity="1" d="M0,96L48,112C96,128,192,160,288,160C384,160,480,128,576,122.7C672,117,768,139,864,154.7C960,171,1056,181,1152,165.3C1248,149,1344,107,1392,85.3L1440,64L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
        </svg>
    </div>
</section>

<!-- Search Section -->
<section class="search-section py-5 bg-light">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-10">
                <div class="card shadow-lg border-0 rounded-4">
                    <div class="card-body p-4">
                        <h3 class="text-center mb-4">Find Your Perfect Event</h3>
                        <form action="/Event" method="get" class="row g-3">
                            <div class="col-md-5">
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0">
                                        <i class="bi bi-search text-primary"></i>
                                    </span>
                                    <input type="text" name="searchTerm" class="form-control border-start-0"
                                           placeholder="Search events, categories, locations...">
                                </div>
                            </div>
                            <div class="col-md-3">
                                <select name="category" class="form-select">
                                    <option value="">All Categories</option>
                                    <option>Conference</option>
                                    <option>Workshop</option>
                                    <option>Music</option>
                                    <option>Networking</option>
                                    <option>Sports</option>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <input type="date" name="date" class="form-control" placeholder="Date">
                            </div>
                            <div class="col-md-2">
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="bi bi-search"></i> Search
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Featured Events Section -->
<section class="featured-events py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold">Featured Events</h2>
            <p class="lead text-muted">Discover the most popular events this week</p>
            <div class="divider mx-auto"></div>
        </div>

        <div class="row g-4">
            <!-- Event Card 1 -->
            <div class="col-md-6 col-lg-4">
                <div class="event-card card h-100 border-0 shadow-sm hover-scale">
                    <div class="card-img-top-wrapper">
                        <img src="https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=400"
                             class="card-img-top" alt="Tech Conference" style="height: 200px; object-fit: cover;">
                        <span class="event-badge bg-danger">Popular</span>
                    </div>
                    <div class="card-body">
                        <div class="event-date mb-2">
                            <i class="bi bi-calendar-event text-primary"></i>
                            <span class="text-muted">March 15, 2024 • 10:00 AM</span>
                        </div>
                        <h5 class="card-title fw-bold">Annual Tech Conference 2024</h5>
                        <p class="card-text text-muted">Join industry leaders for a day of innovation and networking...</p>
                        <div class="event-meta">
                            <span><i class="bi bi-geo-alt"></i> Convention Center</span>
                            <span><i class="bi bi-people"></i> 200+ attending</span>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="price-tag fw-bold text-primary">$99.99</span>
                            <a href="/Event/Details/1" class="btn btn-outline-primary btn-sm">View Details →</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Event Card 2 -->
            <div class="col-md-6 col-lg-4">
                <div class="event-card card h-100 border-0 shadow-sm hover-scale">
                    <div class="card-img-top-wrapper">
                        <img src="https://images.unsplash.com/photo-1459749411175-04bf5292ceea?w=400"
                             class="card-img-top" alt="Music Festival" style="height: 200px; object-fit: cover;">
                        <span class="event-badge bg-success">Free</span>
                    </div>
                    <div class="card-body">
                        <div class="event-date mb-2">
                            <i class="bi bi-calendar-event text-primary"></i>
                            <span class="text-muted">March 20, 2024 • 6:00 PM</span>
                        </div>
                        <h5 class="card-title fw-bold">Summer Music Festival</h5>
                        <p class="card-text text-muted">Live performances from top artists in an outdoor setting...</p>
                        <div class="event-meta">
                            <span><i class="bi bi-geo-alt"></i> City Park</span>
                            <span><i class="bi bi-people"></i> 500+ attending</span>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="price-tag fw-bold text-success">FREE</span>
                            <a href="/Event/Details/2" class="btn btn-outline-primary btn-sm">View Details →</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Event Card 3 -->
            <div class="col-md-6 col-lg-4">
                <div class="event-card card h-100 border-0 shadow-sm hover-scale">
                    <div class="card-img-top-wrapper">
                        <img src="https://images.unsplash.com/photo-1556761175-b413da4baf72?w=400"
                             class="card-img-top" alt="Workshop" style="height: 200px; object-fit: cover;">
                        <span class="event-badge bg-info">Limited</span>
                    </div>
                    <div class="card-body">
                        <div class="event-date mb-2">
                            <i class="bi bi-calendar-event text-primary"></i>
                            <span class="text-muted">March 25, 2024 • 9:00 AM</span>
                        </div>
                        <h5 class="card-title fw-bold">Digital Marketing Workshop</h5>
                        <p class="card-text text-muted">Learn the latest strategies in digital marketing from experts...</p>
                        <div class="event-meta">
                            <span><i class="bi bi-geo-alt"></i> Business Center</span>
                            <span><i class="bi bi-people"></i> 50+ attending</span>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="price-tag fw-bold text-primary">$49.99</span>
                            <a href="/Event/Details/3" class="btn btn-outline-primary btn-sm">View Details →</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="text-center mt-5">
            <a href="/Event" class="btn btn-primary btn-lg px-5">
                Browse All Events
                <i class="bi bi-arrow-right"></i>
            </a>
        </div>
    </div>
</section>

