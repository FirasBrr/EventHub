@model EventHub.ViewModels.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard - EventHub";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Clean system fonts */
    body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
    }

    .dashboard-header {
        background: linear-gradient(135deg, var(--accent-blue) 0%, #2563eb 100%);
        padding: 28px 0;
        margin-bottom: 32px;
    }

        .dashboard-header h1 {
            font-size: 1.5rem;
            font-weight: 600;
            color: white;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

    .stat-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 20px;
        transition: all 0.2s;
        height: 100%;
    }

        .stat-card:hover {
            transform: translateY(-2px);
            border-color: var(--accent-blue);
        }

    .stat-value {
        font-size: 2rem;
        font-weight: 700;
        color: var(--text-hi);
        margin-bottom: 4px;
    }

    .stat-label {
        color: var(--text-lo);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-weight: 500;
    }

    .stat-change {
        font-size: 0.7rem;
        margin-top: 10px;
        padding-top: 8px;
        border-top: 1px solid var(--border);
    }

        .stat-change.positive {
            color: #10b981;
        }

    .dashboard-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 20px;
        height: 100%;
    }

    .card-title {
        font-weight: 600;
        font-size: 0.9rem;
        color: var(--text-hi);
        margin-bottom: 16px;
        padding-bottom: 10px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .card-title i {
            color: var(--accent-blue);
            font-size: 1rem;
        }

    .chart-container {
        position: relative;
        height: 250px;
        margin-top: 8px;
    }

    .event-item, .registration-item {
        padding: 10px 0;
        border-bottom: 1px solid var(--border);
    }

        .event-item:last-child, .registration-item:last-child {
            border-bottom: none;
        }

    .status-badge {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 20px;
        font-size: 0.6rem;
        font-weight: 500;
    }

    .status-active {
        background: rgba(16, 185, 129, 0.1);
        color: #10b981;
    }

    .status-inactive {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
    }

    .status-upcoming {
        background: rgba(59, 130, 246, 0.1);
        color: var(--accent-blue);
    }

    .category-bar {
        background: var(--bg);
        border-radius: 6px;
        height: 6px;
        overflow: hidden;
        margin: 6px 0;
    }

    .category-fill {
        background: var(--accent-blue);
        height: 100%;
        border-radius: 6px;
    }

    .view-all-link {
        color: var(--accent-blue);
        text-decoration: none;
        font-size: 0.7rem;
        font-weight: 500;
    }

    .empty-message {
        text-align: center;
        padding: 30px 20px;
        color: var(--text-lo);
        font-size: 0.8rem;
    }

    .text-muted {
        color: var(--text-lo) !important;
        font-size: 0.7rem;
    }
</style>

<div class="dashboard-header">
    <div class="container">
        <h1>
            <i class="bi bi-speedometer2"></i> Dashboard
        </h1>
    </div>
</div>

<div class="container mb-5">
    <!-- Stats Row 1 -->
    <div class="row g-3 mb-3">
        <div class="col-md-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-value">@Model.TotalEvents</div>
                <div class="stat-label">Total events</div>
                <div class="stat-change positive">+@Model.EventsThisMonth this month</div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-value">@Model.ActiveEvents</div>
                <div class="stat-label">Active events</div>
                <div class="stat-change positive">Upcoming</div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-value">@Model.TotalUsers</div>
                <div class="stat-label">Total users</div>
                <div class="stat-change positive">Active members</div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-value">@Model.TotalRegistrations</div>
                <div class="stat-label">Registrations</div>
                <div class="stat-change positive">+@Model.RegistrationsThisMonth this month</div>
            </div>
        </div>
    </div>

    <!-- Stats Row 2 -->
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="stat-card">
                <div class="stat-value">@Model.TotalRevenue.ToString("C0")</div>
                <div class="stat-label">Revenue</div>
                <div class="stat-change positive">From paid events</div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="stat-card">
                <div class="stat-value">@(Model.TotalEvents > 0 ? (Model.TotalRegistrations / Model.TotalEvents).ToString("F1") : "0")</div>
                <div class="stat-label">Avg per event</div>
                <div class="stat-change positive">Registrations</div>
            </div>
        </div>
    </div>

    <!-- Charts -->
    <div class="row g-3 mb-4">
        <div class="col-lg-6">
            <div class="dashboard-card">
                <div class="card-title">
                    <i class="bi bi-graph-up"></i> Registrations
                    <span class="ms-auto text-muted">Last 6 months</span>
                </div>
                <div class="chart-container">
                    <canvas id="registrationsChart"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="dashboard-card">
                <div class="card-title">
                    <i class="bi bi-pie-chart"></i> Events by category
                </div>
                <div class="chart-container">
                    <canvas id="categoryChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Events & Registrations -->
    <div class="row g-3 mb-4">
        <div class="col-lg-6">
            <div class="dashboard-card">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="card-title mb-0"><i class="bi bi-clock-history"></i> Recent events</div>
                    <a asp-controller="Event" asp-action="Index" class="view-all-link">View all →</a>
                </div>
                @foreach (var eventItem in Model.RecentEvents)
                {
                    <div class="event-item">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                                    <span style="font-weight: 500; font-size: 0.85rem; color: var(--text-hi);">@eventItem.Name</span>
                                    <span class="status-badge @(eventItem.IsActive ? "status-active" : "status-inactive")">
                                        @(eventItem.IsActive ? "Active" : "Inactive")
                                    </span>
                                </div>
                                <div class="text-muted">
                                    <i class="bi bi-calendar3"></i> @eventItem.DateTime.ToString("MMM dd, yyyy")
                                </div>
                                <div class="text-muted mt-1">
                                    <i class="bi bi-people"></i> @eventItem.RegistrationsCount / @eventItem.Capacity
                                </div>
                            </div>
                            <a asp-controller="Event" asp-action="Details" asp-route-id="@eventItem.Id" class="text-muted">
                                <i class="bi bi-eye"></i>
                            </a>
                        </div>
                    </div>
                }
                @if (!Model.RecentEvents.Any())
                {
                    <div class="empty-message">
                        <i class="bi bi-calendar-x"></i>
                        <p class="mt-2 mb-0">No recent events</p>
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-6">
            <div class="dashboard-card">
                <div class="card-title mb-3"><i class="bi bi-activity"></i> Recent registrations</div>
                @foreach (var reg in Model.RecentRegistrations)
                {
                    <div class="registration-item">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div style="font-weight: 500; font-size: 0.85rem; color: var(--text-hi);">
                                    <i class="bi bi-person-circle"></i> @reg.UserName
                                </div>
                                <div class="text-muted">
                                    <i class="bi bi-calendar-event"></i> @reg.EventName
                                </div>
                            </div>
                            <div class="text-end">
                                <div class="text-muted">@reg.RegisteredAt.ToString("MMM dd")</div>
                                <span class="status-badge status-upcoming">Registered</span>
                            </div>
                        </div>
                    </div>
                }
                @if (!Model.RecentRegistrations.Any())
                {
                    <div class="empty-message">
                        <i class="bi bi-ticket"></i>
                        <p class="mt-2 mb-0">No recent registrations</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Categories -->
    <div class="row g-3">
        <div class="col-12">
            <div class="dashboard-card">
                <div class="card-title"><i class="bi bi-tags"></i> Popular categories</div>
                <div class="row">
                    @foreach (var category in Model.PopularCategories)
                    {
                        <div class="col-md-4 mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span style="font-size: 0.8rem; color: var(--text-hi);">@category.Category</span>
                                <span class="text-muted">@category.Count</span>
                            </div>
                            <div class="category-bar">
                                <div class="category-fill" style="width: @category.Percentage%"></div>
                            </div>
                        </div>
                    }
                </div>
                @if (!Model.PopularCategories.Any())
                {
                    <div class="empty-message">
                        <i class="bi bi-tag"></i>
                        <p class="mt-2 mb-0">No categories yet</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        // Registrations Chart
        const registrationsCtx = document.getElementById('registrationsChart').getContext('2d');
        new Chart(registrationsCtx, {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.RegistrationsByMonth.Labels)),
                datasets: [{
                    label: 'Registrations',
                    data: @Html.Raw(Json.Serialize(Model.RegistrationsByMonth.Data)),
                    borderColor: '#3b82f6',
                    backgroundColor: 'rgba(59, 130, 246, 0.05)',
                    borderWidth: 2,
                    pointBackgroundColor: '#3b82f6',
                    pointBorderColor: '#fff',
                    pointBorderWidth: 2,
                    pointRadius: 3,
                    pointHoverRadius: 5,
                    tension: 0.3,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: { display: false },
                    tooltip: { backgroundColor: '#1e293b' }
                },
                scales: {
                    y: { beginAtZero: true, grid: { color: '#e2e8f0' }, ticks: { stepSize: 1, color: '#64748b' } },
                    x: { grid: { display: false }, ticks: { color: '#64748b' } }
                }
            }
        });

        // Categories Chart
        const categoryCtx = document.getElementById('categoryChart').getContext('2d');
        new Chart(categoryCtx, {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.EventsByCategory.Labels)),
                datasets: [{
                    data: @Html.Raw(Json.Serialize(Model.EventsByCategory.Data)),
                    backgroundColor: ['#3b82f6', '#ef4444', '#f59e0b', '#10b981', '#8b5cf6'],
                    borderWidth: 0,
                    hoverOffset: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { color: '#64748b', font: { size: 10 }, usePointStyle: true, pointStyle: 'circle' }
                    }
                },
                cutout: '60%'
            }
        });
    </script>
}