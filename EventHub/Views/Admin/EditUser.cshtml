@model EventHub.Models.ApplicationUser

@{
    ViewData["Title"] = "Edit User - Admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .edit-container {
        max-width: 600px;
        margin: 0 auto;
        padding: 40px 20px;
    }

    .edit-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 28px;
    }

    .edit-header {
        margin-bottom: 24px;
    }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group label {
            font-size: 0.8rem;
            font-weight: 500;
            color: var(--text-md);
            margin-bottom: 6px;
            display: block;
        }

    .form-control {
        width: 100%;
        padding: 10px 14px;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 10px;
    }

    .checkbox-group {
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 20px 0;
    }

    .btn-save {
        background: var(--accent-blue);
        color: white;
        border: none;
        padding: 10px 24px;
        border-radius: 10px;
        cursor: pointer;
    }

    .btn-cancel {
        background: transparent;
        border: 1px solid var(--border);
        padding: 10px 24px;
        border-radius: 10px;
        text-decoration: none;
        color: var(--text-md);
        margin-left: 10px;
    }
</style>

<div class="edit-container">
    <div class="edit-card">
        <div class="edit-header"><h1><i class="bi bi-pencil-square"></i> Edit User</h1></div>
        <form asp-action="EditUser" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div class="form-group"><label asp-for="FirstName"></label><input asp-for="FirstName" class="form-control" /></div>
            <div class="form-group"><label asp-for="LastName"></label><input asp-for="LastName" class="form-control" /></div>
            <div class="form-group"><label asp-for="UserName"></label><input asp-for="UserName" class="form-control" /></div>
            <div class="form-group"><label asp-for="Email"></label><input asp-for="Email" class="form-control" type="email" /></div>
            <div class="checkbox-group"><input asp-for="IsActive" type="checkbox" /> <label>Account is active</label></div>
            <button type="submit" class="btn-save">Save changes</button>
            <a asp-action="ManageUsers" class="btn-cancel">Cancel</a>
        </form>
    </div>
</div>