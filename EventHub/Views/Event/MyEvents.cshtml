@model IEnumerable<EventHub.Models.Event>

@{
    ViewData["Title"] = "My Events - EventHub";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .myevents-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 40px 20px;
    }

    .page-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--text-hi);
        margin-bottom: 8px;
    }

    .page-subtitle {
        color: var(--text-lo);
        margin-bottom: 32px;
        font-size: 0.9rem;
    }

    /* Stats row */
    .stats-row {
        display: flex;
        gap: 12px;
        margin-bottom: 32px;
        flex-wrap: wrap;
    }

    .stat-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 12px 20px;
        font-size: 0.85rem;
        color: var(--text-md);
    }

        .stat-card strong {
            color: var(--accent-blue);
            font-size: 1.1rem;
            margin-right: 4px;
        }

    /* Event card */
    .event-item {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 16px;
        transition: all 0.2s;
    }

        .event-item:hover {
            border-color: var(--accent-blue);
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
        }

    .event-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 12px;
        flex-wrap: wrap;
        gap: 12px;
    }

    .event-name {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--text-hi);
    }

    .status-badge {
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .badge-upcoming {
        background: #e0f2fe;
        color: #0369a1;
    }

    .badge-today {
        background: #fef3c7;
        color: #b45309;
    }

    .badge-past {
        background: #f1f5f9;
        color: #475569;
    }

    /* Event details grid */
    .event-details {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        margin-bottom: 16px;
    }

    .detail {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.8rem;
        color: var(--text-lo);
    }

        .detail i {
            color: var(--accent-blue);
            width: 16px;
            font-size: 0.8rem;
        }

    .event-description {
        color: var(--text-lo);
        font-size: 0.8rem;
        margin-bottom: 16px;
        line-height: 1.5;
    }

    .event-actions {
        display: flex;
        gap: 12px;
        padding-top: 12px;
        border-top: 1px solid var(--border);
    }

    .btn-view {
        background: transparent;
        border: 1px solid var(--border);
        color: var(--text-md);
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.2s;
    }

        .btn-view:hover {
            border-color: var(--accent-blue);
            color: var(--accent-blue);
            background: rgba(59, 130, 246, 0.05);
        }

    .btn-cancel {
        background: transparent;
        border: 1px solid #fecaca;
        color: #dc2626;
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-cancel:hover {
            background: #fef2f2;
            border-color: #dc2626;
        }

    /* Empty state */
    .empty-state {
        text-align: center;
        padding: 60px 20px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 20px;
    }

        .empty-state i {
            font-size: 3rem;
            color: var(--text-lo);
            margin-bottom: 16px;
        }

        .empty-state p {
            color: var(--text-lo);
            margin-bottom: 20px;
        }

    .btn-browse {
        background: var(--accent-blue);
        color: white;
        padding: 10px 24px;
        border-radius: 30px;
        font-size: 0.85rem;
        font-weight: 500;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
    }

        .btn-browse:hover {
            background: #2563eb;
            transform: translateY(-1px);
            color: white;
        }
</style>

<div class="myevents-container">
    <h1 class="page-title">My Events</h1>
    <p class="page-subtitle">Events you've registered for</p>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="bi bi-calendar-heart"></i>
            <p>You haven't registered for any events yet.</p>
            <a href="/Event" class="btn-browse">
                <i class="bi bi-search"></i> Browse events
            </a>
        </div>
    }
    else
    {
        <div class="stats-row">
            <div class="stat-card">
                <strong>@Model.Count()</strong> total events
            </div>
            <div class="stat-card">
                <strong>@Model.Count(e => e.DateTime > DateTime.Now)</strong> upcoming
            </div>
        </div>

        @foreach (var item in Model)
        {
            var isUpcoming = item.DateTime > DateTime.Now;
            var isToday = item.DateTime.Date == DateTime.Now.Date;
            var statusClass = isToday ? "badge-today" : (isUpcoming ? "badge-upcoming" : "badge-past");
            var statusText = isToday ? "Today" : (isUpcoming ? "Upcoming" : "Past");

            <div class="event-item">
                <div class="event-header">
                    <span class="event-name">@item.Name</span>
                    <span class="status-badge @statusClass">@statusText</span>
                </div>

                <div class="event-details">
                    <span class="detail"><i class="bi bi-calendar3"></i> @item.DateTime.ToString("MMM dd, yyyy")</span>
                    <span class="detail"><i class="bi bi-clock"></i> @item.DateTime.ToString("h:mm tt")</span>
                    <span class="detail"><i class="bi bi-geo-alt"></i> @item.Location</span>
                    <span class="detail"><i class="bi bi-tag"></i> @item.Category</span>
                </div>

                <div class="event-description">
                    @(item.Description.Length > 120 ? item.Description.Substring(0, 120) + "..." : item.Description)
                </div>

                <div class="event-actions">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn-view">
                        <i class="bi bi-eye"></i> View details
                    </a>
                    @if (isUpcoming)
                    {
                        <form asp-action="CancelRegistration" asp-route-id="@item.Id" method="post"
                              onsubmit="return confirm('Cancel registration for @item.Name?');"
                              style="display: inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-cancel">
                                <i class="bi bi-x"></i> Cancel
                            </button>
                        </form>
                    }
                </div>
            </div>
        }
    }
</div>