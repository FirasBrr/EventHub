@model IEnumerable<EventHub.Models.Event>

@{
    ViewData["Title"] = "Events";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-calendar-event"></i> Upcoming Events</h1>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Create New Event
            </a>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No upcoming events found.
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create">Create the first event!</a>
            }
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        @if (item.Latitude.HasValue && item.Longitude.HasValue)
                        {
                            <div id="miniMap-@item.Id" style="height: 200px;" class="card-img-top"></div>
                        }
                        else
                        {
                            <div class="bg-secondary text-white text-center py-5">
                                <i class="bi bi-map" style="font-size: 3rem;"></i>
                                <p>Location TBD</p>
                            </div>
                        }

                        <div class="card-body">
                            <h5 class="card-title">@item.Name</h5>
                            <p class="card-text text-muted">
                                <i class="bi bi-calendar"></i> @item.DateTime.ToString("MMM dd, yyyy - h:mm tt")<br />
                                <i class="bi bi-geo-alt"></i> @item.Location<br />
                                <i class="bi bi-tag"></i> @item.Category
                            </p>
                            <p class="card-text">@(item.Description.Length > 100 ? item.Description.Substring(0, 100) + "..." : item.Description)</p>
                            <p>
                                @if (item.IsFree)
                                {
                                    <span class="badge bg-success">FREE</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary">@item.Price.ToString("C")</span>
                                }
                                <span class="badge bg-info">@item.Capacity spots</span>
                            </p>
                        </div>
                        <div class="card-footer bg-transparent">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">View Details</a>
                            @if (User.Identity.IsAuthenticated)
                            {
                                <a asp-action="Register" asp-route-id="@item.Id" class="btn btn-success btn-sm">Register</a>
                            }
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        @foreach (var item in Model.Where(e => e.Latitude.HasValue && e.Longitude.HasValue))
        {
                <text>
                var map@(item.Id) = L.map('miniMap-@item.Id').setView([@item.Latitude, @item.Longitude], 13);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '&copy; OpenStreetMap'
                }).addTo(map@(item.Id));
                L.marker([@item.Latitude, @item.Longitude]).addTo(map@(item.Id))
                    .bindPopup('@item.Name');
                </text>
        }
    </script>
}