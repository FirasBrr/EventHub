@model IEnumerable<EventHub.Models.Event>

@{
    ViewData["Title"] = "Discover Events - EventHub";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .events-header {
        background: linear-gradient(135deg, #00d2ff 0%, #3a7bd5 100%);
        padding: 3rem 0;
        margin-bottom: 2rem;
        border-radius: 0 0 30px 30px;
    }

    .filter-card {
        background: rgba(26, 26, 46, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 15px;
        border: 1px solid rgba(0, 210, 255, 0.2);
        margin-bottom: 2rem;
        padding: 1.5rem;
    }

    .filter-section {
        border-bottom: 1px solid rgba(0, 210, 255, 0.1);
        padding-bottom: 1rem;
        margin-bottom: 1rem;
    }

        .filter-section:last-child {
            border-bottom: none;
            padding-bottom: 0;
            margin-bottom: 0;
        }

    .filter-title {
        color: #00d2ff;
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 0.75rem;
    }

    .price-range {
        display: flex;
        gap: 10px;
        align-items: center;
    }

        .price-range input {
            width: 100px;
        }

    .sort-badge {
        display: inline-block;
        padding: 5px 12px;
        background: rgba(0, 210, 255, 0.1);
        border-radius: 20px;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-right: 8px;
        margin-bottom: 8px;
    }

        .sort-badge:hover, .sort-badge.active {
            background: rgba(0, 210, 255, 0.3);
            color: #00d2ff;
        }

    .event-card {
        background: rgba(26, 26, 46, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 15px;
        border: 1px solid rgba(0, 210, 255, 0.1);
        transition: all 0.3s ease;
        overflow: hidden;
        height: 100%;
    }

        .event-card:hover {
            transform: translateY(-5px);
            border-color: rgba(0, 210, 255, 0.5);
            box-shadow: 0 10px 30px rgba(0, 210, 255, 0.2);
        }

    .event-image {
        height: 200px;
        object-fit: cover;
        width: 100%;
    }

    .event-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        padding: 5px 15px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: bold;
        z-index: 1;
    }

    .event-category {
        display: inline-block;
        padding: 4px 12px;
        background: rgba(0, 210, 255, 0.2);
        border-radius: 20px;
        font-size: 12px;
        color: #00d2ff;
    }

    .event-meta {
        display: flex;
        gap: 15px;
        font-size: 14px;
        color: #a0a0b0;
        margin: 10px 0;
    }

        .event-meta i {
            color: #00d2ff;
            margin-right: 5px;
        }

    .price-tag {
        font-size: 1.3rem;
        font-weight: bold;
        background: linear-gradient(135deg, #00d2ff 0%, #3a7bd5 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .btn-view {
        background: linear-gradient(135deg, #00d2ff 0%, #3a7bd5 100%);
        color: white;
        padding: 8px 20px;
        border-radius: 25px;
        transition: all 0.3s ease;
        border: none;
        display: inline-block;
        text-decoration: none;
        font-size: 0.875rem;
    }

        .btn-view:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0, 210, 255, 0.4);
            color: white;
        }

    .btn-register-event {
        background: transparent;
        border: 2px solid #00d2ff;
        color: #00d2ff;
        padding: 6px 18px;
        border-radius: 25px;
        transition: all 0.3s ease;
        display: inline-block;
        text-decoration: none;
        font-size: 0.875rem;
    }

        .btn-register-event:hover {
            background: rgba(0, 210, 255, 0.1);
            transform: translateY(-2px);
            color: #00d2ff;
        }

    .empty-state {
        text-align: center;
        padding: 4rem;
        background: rgba(26, 26, 46, 0.95);
        border-radius: 15px;
        border: 1px solid rgba(0, 210, 255, 0.2);
    }

        .empty-state i {
            font-size: 4rem;
            color: #00d2ff;
            margin-bottom: 1rem;
        }

    .search-input, .filter-select {
        background: rgba(26, 26, 46, 0.9);
        border: 1px solid rgba(0, 210, 255, 0.2);
        color: white;
    }

        .search-input:focus, .filter-select:focus {
            background: rgba(26, 26, 46, 1);
            border-color: #00d2ff;
            box-shadow: 0 0 0 0.2rem rgba(0, 210, 255, 0.25);
            color: white;
        }

    .results-count {
        color: #00d2ff;
        font-weight: 500;
    }

    .clear-filters {
        color: #dc3545;
        text-decoration: none;
        font-size: 0.85rem;
    }

        .clear-filters:hover {
            text-decoration: underline;
        }

    .bg-gradient {
        background: linear-gradient(135deg, rgba(0,210,255,0.2), rgba(58,123,213,0.2));
    }

    @@media (max-width: 768px) {
        .events-header {
            padding: 2rem 0;
        }

        .filter-card {
            padding: 1rem;
        }

        .price-range {
            flex-direction: column;
            align-items: stretch;
        }

            .price-range input {
                width: 100%;
            }
    }
</style>

<div class="events-header">
    <div class="container">
        <h1 class="text-white text-center mb-3">
            <i class="bi bi-calendar-event-fill"></i> Discover Events
        </h1>
        <p class="text-white text-center opacity-75">Find and join amazing events happening near you</p>
    </div>
</div>

<div class="container mb-5">
    <!-- Advanced Filter Section -->
    <div class="filter-card">
        <form asp-action="Index" method="get" id="filterForm">
            <!-- Search Bar -->
            <div class="filter-section">
                <div class="input-group">
                    <span class="input-group-text bg-transparent" style="border-color: rgba(0,210,255,0.2); color: #00d2ff;">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text" name="searchTerm" id="searchTerm" class="form-control search-input"
                           placeholder="Search by name, description, or location..."
                           value="@ViewBag.CurrentSearchTerm">
                </div>
            </div>

            <!-- Category Filter -->
            <div class="filter-section">
                <div class="filter-title">
                    <i class="bi bi-tag"></i> Category
                </div>
                <select name="category" id="category" class="form-select filter-select">
                    <option value="">All Categories</option>
                    <option value="Conference">Conference</option>
                    <option value="Workshop">Workshop</option>
                    <option value="Music">Music</option>
                    <option value="Networking">Networking</option>
                    <option value="Sports">Sports</option>
                </select>
            </div>

            <!-- Price Range Filter -->
            <div class="filter-section">
                <div class="filter-title">
                    <i class="bi bi-currency-dollar"></i> Price Range
                </div>
                <div class="price-range">
                    <div class="flex-grow-1">
                        <label class="small text-muted">Min Price ($)</label>
                        <input type="number" name="minPrice" id="minPrice" class="form-control search-input"
                               placeholder="0" value="@ViewBag.MinPrice" step="10">
                    </div>
                    <div class="flex-grow-1">
                        <label class="small text-muted">Max Price ($)</label>
                        <input type="number" name="maxPrice" id="maxPrice" class="form-control search-input"
                               placeholder="Any" value="@ViewBag.MaxPrice" step="10">
                    </div>
                </div>
                <div class="form-check mt-2">
                    <input type="checkbox" name="showFree" id="showFree" class="form-check-input"
                           value="true" @(ViewBag.ShowFree == true ? "checked" : "")>
                    <label class="form-check-label text-white" for="showFree">
                        <i class="bi bi-gift"></i> Show only free events
                    </label>
                </div>
            </div>

            <!-- Date Range Filter -->
            <div class="filter-section">
                <div class="filter-title">
                    <i class="bi bi-calendar"></i> Date Range
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <label class="small text-muted">From</label>
                        <input type="date" name="dateFrom" id="dateFrom" class="form-control search-input"
                               value="@ViewBag.DateFrom">
                    </div>
                    <div class="col-md-6">
                        <label class="small text-muted">To</label>
                        <input type="date" name="dateTo" id="dateTo" class="form-control search-input"
                               value="@ViewBag.DateTo">
                    </div>
                </div>
            </div>

            <!-- Sorting Options -->
            <div class="filter-section">
                <div class="filter-title">
                    <i class="bi bi-sort-up"></i> Sort By
                </div>
                <div>
                    <div class="sort-badge @(ViewBag.SortBy == "date_asc" ? "active" : "")" data-sort="date_asc">
                        <i class="bi bi-calendar"></i> Date (Earliest)
                    </div>
                    <div class="sort-badge @(ViewBag.SortBy == "date_desc" ? "active" : "")" data-sort="date_desc">
                        <i class="bi bi-calendar"></i> Date (Latest)
                    </div>
                    <div class="sort-badge @(ViewBag.SortBy == "price_asc" ? "active" : "")" data-sort="price_asc">
                        <i class="bi bi-arrow-up"></i> Price (Low to High)
                    </div>
                    <div class="sort-badge @(ViewBag.SortBy == "price_desc" ? "active" : "")" data-sort="price_desc">
                        <i class="bi bi-arrow-down"></i> Price (High to Low)
                    </div>
                    <div class="sort-badge @(ViewBag.SortBy == "popularity" ? "active" : "")" data-sort="popularity">
                        <i class="bi bi-graph-up"></i> Most Popular
                    </div>
                </div>
                <input type="hidden" name="sortBy" id="sortBy" value="@ViewBag.SortBy">
            </div>

            <!-- Action Buttons -->
            <div class="d-flex justify-content-between align-items-center mt-3">
                <button type="submit" class="btn-view">
                    <i class="bi bi-search"></i> Apply Filters
                </button>
                <a href="/Event" class="clear-filters">
                    <i class="bi bi-x-circle"></i> Clear All Filters
                </a>
            </div>
        </form>
    </div>

    <!-- Results Count -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="results-count">
            <i class="bi bi-calendar-check"></i> Found <strong>@Model.Count()</strong> events
        </div>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn-view">
                <i class="bi bi-plus-circle"></i> Create New Event
            </a>
        }
    </div>

    <!-- Events Grid -->
    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="bi bi-calendar-x"></i>
            <h3 class="text-white">No events found</h3>
            <p class="text-muted">Try adjusting your filters or check back later for new events.</p>
            <a href="/Event" class="btn-view mt-3" style="display: inline-block;">Clear Filters</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="event-card">
                        <div class="position-relative">
                            @if (item.Latitude.HasValue && item.Longitude.HasValue)
                            {
                                <div id="miniMap-@item.Id" class="event-image" style="height: 200px;"></div>
                            }
                            else
                            {
                                <div class="event-image bg-gradient d-flex align-items-center justify-content-center" style="background: linear-gradient(135deg, rgba(0,210,255,0.2), rgba(58,123,213,0.2));">
                                    <i class="bi bi-map" style="font-size: 3rem; color: #00d2ff;"></i>
                                </div>
                            }
                            <span class="event-badge" style="background: @(item.IsFree ? "#28a745" : "#00d2ff")">
                                @(item.IsFree ? "FREE" : "PAID")
                            </span>
                        </div>

                        <div class="p-3">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="event-category">
                                    <i class="bi bi-tag"></i> @item.Category
                                </span>
                                <small class="text-muted">
                                    <i class="bi bi-people"></i> @(item.Registrations?.Count ?? 0)/@item.Capacity
                                </small>
                            </div>

                            <h5 class="text-white fw-bold mb-2">@item.Name</h5>

                            <div class="event-meta">
                                <span><i class="bi bi-calendar"></i> @item.DateTime.ToString("MMM dd, yyyy")</span>
                                <span><i class="bi bi-clock"></i> @item.DateTime.ToString("h:mm tt")</span>
                            </div>

                            <div class="event-meta">
                                <span><i class="bi bi-geo-alt"></i> @item.Location</span>
                            </div>

                            <p class="text-muted small mt-2">@(item.Description.Length > 100 ? item.Description.Substring(0, 100) + "..." : item.Description)</p>

                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="price-tag">@(item.IsFree ? "FREE" : item.Price.ToString("C"))</span>
                                <div>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn-view" style="padding: 6px 15px; font-size: 0.8rem; margin-right: 5px;">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                    @if (User.Identity.IsAuthenticated && !User.IsInRole("Admin"))
                                    {
                                        <a asp-action="Register" asp-route-id="@item.Id" class="btn-register-event" style="padding: 6px 15px; font-size: 0.8rem;">
                                            <i class="bi bi-ticket"></i> Register
                                        </a>
                                    }
                                </div>
                            </div>

                            @if (User.IsInRole("Admin"))
                            {
                                <div class="mt-3 pt-2 border-top" style="border-color: rgba(0,210,255,0.1);">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="text-warning me-3 text-decoration-none small">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="text-danger text-decoration-none small">
                                        <i class="bi bi-trash"></i> Delete
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script>
        // Sort badge click handler
        document.querySelectorAll('.sort-badge').forEach(badge => {
            badge.addEventListener('click', function() {
                const sortValue = this.getAttribute('data-sort');
                document.getElementById('sortBy').value = sortValue;
                document.getElementById('filterForm').submit();
            });
        });

        // Auto-submit on checkbox change
        document.getElementById('showFree').addEventListener('change', function() {
            document.getElementById('filterForm').submit();
        });

        // Debounced search (optional - submits after typing stops)
        let searchTimeout;
        document.getElementById('searchTerm').addEventListener('input', function() {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => {
                document.getElementById('filterForm').submit();
            }, 500);
        });

        // Map initialization for mini maps
        @foreach (var item in Model.Where(e => e.Latitude.HasValue && e.Longitude.HasValue))
        {
                <text>
                var map@(item.Id) = L.map('miniMap-@item.Id').setView([@item.Latitude, @item.Longitude], 13);
                L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
                    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a>'
                }).addTo(map@(item.Id));
                L.marker([@item.Latitude, @item.Longitude]).addTo(map@(item.Id))
                    .bindPopup('<b>@item.Name</b><br/>@item.Location');
                </text>
        }
    </script>
}