@using System.Security.Claims
@model EventHub.Models.Event

@{
    ViewData["Title"] = "Edit Event - EventHub";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .edit-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 2rem;
    }

    .form-card {
        background: rgba(26, 26, 46, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        border: 1px solid rgba(0, 210, 255, 0.2);
        overflow: hidden;
    }

    .form-header {
        background: linear-gradient(135deg, #ffc107 0%, #ff9800 100%);
        padding: 1.5rem;
        text-align: center;
    }

    .form-body {
        padding: 2rem;
    }

    .form-label {
        color: #00d2ff;
        font-weight: 500;
        margin-bottom: 0.5rem;
    }

    .form-control, .form-select {
        background: rgba(26, 26, 46, 0.9);
        border: 1px solid rgba(0, 210, 255, 0.2);
        color: white;
        padding: 0.75rem 1rem;
    }

        .form-control:focus, .form-select:focus {
            background: rgba(26, 26, 46, 1);
            border-color: #ffc107;
            box-shadow: 0 0 0 0.2rem rgba(255, 193, 7, 0.25);
            color: white;
        }

    .input-group-text {
        background: rgba(26, 26, 46, 0.9);
        border: 1px solid rgba(0, 210, 255, 0.2);
        color: #ffc107;
    }

    #map {
        height: 400px;
        border-radius: 15px;
        border: 1px solid rgba(0, 210, 255, 0.3);
    }

    .btn-submit {
        background: linear-gradient(135deg, #ffc107 0%, #ff9800 100%);
        color: #1a1a2e;
        padding: 12px 30px;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s ease;
        border: none;
    }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(255, 193, 7, 0.4);
        }

    .btn-cancel {
        background: transparent;
        border: 2px solid rgba(0, 210, 255, 0.5);
        color: #00d2ff;
        padding: 10px 30px;
        border-radius: 10px;
        transition: all 0.3s ease;
    }

        .btn-cancel:hover {
            background: rgba(0, 210, 255, 0.1);
        }

    .info-card {
        background: rgba(0, 210, 255, 0.1);
        border-left: 4px solid #ffc107;
        padding: 1rem;
        border-radius: 10px;
        margin-top: 1rem;
    }

    .text-danger {
        color: #ff6666 !important;
        font-size: 0.8rem;
    }
</style>

<div class="container edit-container">
    <div class="form-card">
        <div class="form-header">
            <h2 class="text-white mb-0">
                <i class="bi bi-pencil-square"></i> Edit Event
            </h2>
            <p class="text-white opacity-75 mt-2">Update your event information</p>
        </div>

        <div class="form-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="CreatedAt" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="background: rgba(255,0,0,0.1); border: none; color: #ff6666;"></div>

                <div class="row">
                    <div class="col-md-12 mb-3">
                        <label asp-for="Name" class="form-label">
                            <i class="bi bi-tag"></i> Event Name
                        </label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">
                        <i class="bi bi-file-text"></i> Description
                    </label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="DateTime" class="form-label">
                            <i class="bi bi-calendar"></i> Date & Time
                        </label>
                        <input asp-for="DateTime" class="form-control" type="datetime-local" />
                        <span asp-validation-for="DateTime" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Category" class="form-label">
                            <i class="bi bi-grid"></i> Category
                        </label>
                        <select asp-for="Category" class="form-select">
                            <option value="Conference">Conference</option>
                            <option value="Workshop">Workshop</option>
                            <option value="Music">Music</option>
                            <option value="Networking">Networking</option>
                            <option value="Sports">Sports</option>
                        </select>
                        <span asp-validation-for="Category" class="text-danger"></span>
                    </div>
                </div>

                <!-- Location with Map -->
                <div class="mb-3">
                    <label asp-for="FullAddress" class="form-label">
                        <i class="bi bi-geo-alt"></i> Location Address
                    </label>
                    <input asp-for="FullAddress" id="addressInput" class="form-control"
                           placeholder="Enter full address" />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Latitude" class="form-label">
                            <i class="bi bi-arrow-up"></i> Latitude
                        </label>
                        <input asp-for="Latitude" id="latitude" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Longitude" class="form-label">
                            <i class="bi bi-arrow-right"></i> Longitude
                        </label>
                        <input asp-for="Longitude" id="longitude" class="form-control" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">
                        <i class="bi bi-map"></i> Click on map to update location
                    </label>
                    <div id="map"></div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Location" class="form-label">
                            <i class="bi bi-building"></i> Venue Name
                        </label>
                        <input asp-for="Location" class="form-control" />
                        <span asp-validation-for="Location" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Capacity" class="form-label">
                            <i class="bi bi-people"></i> Capacity
                        </label>
                        <input asp-for="Capacity" class="form-control" />
                        <span asp-validation-for="Capacity" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <div class="form-check">
                            <input asp-for="IsFree" class="form-check-input" id="isFreeCheckbox" />
                            <label asp-for="IsFree" class="form-check-label text-white">
                                <i class="bi bi-gift"></i> This is a free event
                            </label>
                        </div>
                    </div>

                    <div class="col-md-6 mb-3" id="priceField">
                        <label asp-for="Price" class="form-label">
                            <i class="bi bi-currency-dollar"></i> Ticket Price
                        </label>
                        <input asp-for="Price" class="form-control" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                </div>

                <div class="info-card">
                    <small>
                        <i class="bi bi-info-circle"></i>
                        <strong class="text-white">Tip:</strong> Click on the map to update the event location, or enter an address.
                    </small>
                </div>

                <div class="mt-4 d-flex gap-3">
                    <button type="submit" class="btn-submit">
                        <i class="bi bi-save"></i> Save Changes
                    </button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn-cancel">
                        <i class="bi bi-x-lg"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        var map;
        var marker;

        function initMap() {
            var lat = @(Model.Latitude ?? 40.7128);
            var lng = @(Model.Longitude ?? -74.0060);

            map = L.map('map').setView([lat, lng], 13);

            L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; OpenStreetMap'
            }).addTo(map);

            if (lat != 40.7128 || lng != -74.0060) {
                marker = L.marker([lat, lng]).addTo(map);
            }

            map.on('click', function(e) {
                var newLat = e.latlng.lat;
                var newLng = e.latlng.lng;

                document.getElementById('latitude').value = newLat.toFixed(6);
                document.getElementById('longitude').value = newLng.toFixed(6);

                if (marker) {
                    marker.setLatLng(e.latlng);
                } else {
                    marker = L.marker(e.latlng).addTo(map);
                }

                reverseGeocode(newLat, newLng);
            });
        }

        function reverseGeocode(lat, lng) {
            fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}&zoom=18`)
                .then(response => response.json())
                .then(data => {
                    if (data.display_name) {
                        document.getElementById('addressInput').value = data.display_name;
                    }
                })
                .catch(error => console.log('Geocoding error:', error));
        }

        document.getElementById('addressInput').addEventListener('blur', function() {
            var address = this.value;
            if (address) {
                fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(address)}`)
                    .then(response => response.json())
                    .then(data => {
                        if (data && data.length > 0) {
                            var lat = data[0].lat;
                            var lng = data[0].lon;

                            document.getElementById('latitude').value = lat;
                            document.getElementById('longitude').value = lng;

                            map.setView([lat, lng], 15);
                            if (marker) {
                                marker.setLatLng([lat, lng]);
                            } else {
                                marker = L.marker([lat, lng]).addTo(map);
                            }
                        }
                    });
            }
        });

        document.getElementById('isFreeCheckbox').addEventListener('change', function() {
            var priceField = document.getElementById('priceField');
            var priceInput = document.querySelector('#Price');
            if (this.checked) {
                priceField.style.display = 'none';
                priceInput.value = 0;
            } else {
                priceField.style.display = 'block';
            }
        });

        initMap();
    </script>
}