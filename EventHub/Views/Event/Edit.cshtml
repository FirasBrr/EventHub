@model EventHub.Models.Event

@{
    ViewData["Title"] = "Edit Event - EventHub";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .form-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 32px 20px;
    }

    .form-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
    }

    .form-header {
        background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
        padding: 28px 24px;
        text-align: center;
    }

        .form-header h2 {
            font-family: 'Syne', sans-serif;
            font-size: 1.6rem;
            font-weight: 800;
            color: white;
            margin-bottom: 6px;
        }

    .form-body {
        padding: 28px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--text-md);
        margin-bottom: 8px;
        display: block;
    }

        .form-label i {
            color: #f59e0b;
            margin-right: 6px;
        }

    .form-control, .form-select {
        width: 100%;
        padding: 10px 14px;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        color: var(--text-hi);
        font-size: 0.875rem;
    }

        .form-control:focus, .form-select:focus {
            outline: none;
            border-color: #f59e0b;
            box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.1);
        }

    #map {
        height: 320px;
        border-radius: var(--radius-sm);
        border: 1px solid var(--border);
        margin-top: 8px;
    }

    .checkbox-group {
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 16px 0;
    }

    .info-tip {
        background: rgba(245, 158, 11, 0.08);
        border-left: 3px solid #f59e0b;
        padding: 12px 16px;
        border-radius: var(--radius-sm);
        margin: 20px 0;
        font-size: 0.8rem;
    }

    .btn-submit {
        background: #f59e0b;
        color: white;
        border: none;
        padding: 12px 28px;
        border-radius: var(--radius-sm);
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-submit:hover {
            background: #d97706;
        }

    .btn-cancel {
        background: transparent;
        border: 1px solid var(--border);
        color: var(--text-md);
        padding: 11px 28px;
        border-radius: var(--radius-sm);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-cancel:hover {
            border-color: var(--accent-red);
            color: var(--accent-red);
        }
</style>

<div class="form-container">
    <div class="form-card">
        <div class="form-header">
            <h2><i class="bi bi-pencil-square"></i> Edit event</h2>
            <p style="color: rgba(255,255,255,0.8);">Update your event information</p>
        </div>

        <div class="form-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="CreatedAt" />

                <div asp-validation-summary="ModelOnly" class="validation-summary" style="background: rgba(239,68,68,0.08); padding: 12px; border-radius: 8px; margin-bottom: 20px; color: #dc2626;"></div>

                <div class="form-group">
                    <label asp-for="Name" class="form-label"><i class="bi bi-tag"></i> Event name</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Description" class="form-label"><i class="bi bi-file-text"></i> Description</label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="row" style="display: flex; gap: 16px; flex-wrap: wrap;">
                    <div style="flex: 1;">
                        <label asp-for="DateTime" class="form-label"><i class="bi bi-calendar"></i> Date & time</label>
                        <input asp-for="DateTime" class="form-control" type="datetime-local" />
                    </div>
                    <div style="flex: 1;">
                        <label asp-for="Category" class="form-label"><i class="bi bi-grid"></i> Category</label>
                        <select asp-for="Category" class="form-select">
                            <option>Conference</option>
                            <option>Workshop</option>
                            <option>Music</option>
                            <option>Networking</option>
                            <option>Sports</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label"><i class="bi bi-geo-alt"></i> Location address</label>
                    <input asp-for="FullAddress" id="addressInput" class="form-control" />
                </div>

                <div class="row" style="display: flex; gap: 16px; flex-wrap: wrap;">
                    <div style="flex: 1;">
                        <label asp-for="Latitude" class="form-label"><i class="bi bi-arrow-up"></i> Latitude</label>
                        <input asp-for="Latitude" id="latitude" class="form-control" />
                    </div>
                    <div style="flex: 1;">
                        <label asp-for="Longitude" class="form-label"><i class="bi bi-arrow-right"></i> Longitude</label>
                        <input asp-for="Longitude" id="longitude" class="form-control" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label"><i class="bi bi-map"></i> Click on map to update location</label>
                    <div id="map"></div>
                </div>

                <div class="row" style="display: flex; gap: 16px; flex-wrap: wrap;">
                    <div style="flex: 1;">
                        <label asp-for="Location" class="form-label"><i class="bi bi-building"></i> Venue name</label>
                        <input asp-for="Location" class="form-control" />
                    </div>
                    <div style="flex: 1;">
                        <label asp-for="Capacity" class="form-label"><i class="bi bi-people"></i> Capacity</label>
                        <input asp-for="Capacity" class="form-control" />
                    </div>
                </div>

                <div class="checkbox-group">
                    <input asp-for="IsFree" id="isFreeCheckbox" type="checkbox" />
                    <label asp-for="IsFree">This is a free event</label>
                </div>

                <div class="form-group" id="priceField">
                    <label asp-for="Price" class="form-label"><i class="bi bi-currency-dollar"></i> Ticket price</label>
                    <input asp-for="Price" class="form-control" />
                </div>

                <div class="info-tip">
                    <i class="bi bi-info-circle"></i> <strong>Tip:</strong> Click on the map to update the event location.
                </div>

                <div style="display: flex; gap: 12px; margin-top: 24px;">
                    <button type="submit" class="btn-submit"><i class="bi bi-save"></i> Save changes</button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn-cancel"><i class="bi bi-x-lg"></i> Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        var map, marker;
        var lat = @(Model.Latitude ?? 40.7128);
        var lng = @(Model.Longitude ?? -74.0060);

        function initMap() {
            map = L.map('map').setView([lat, lng], 13);
            L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; OpenStreetMap'
            }).addTo(map);

            if (lat != 40.7128 || lng != -74.0060) {
                marker = L.marker([lat, lng]).addTo(map);
            }

            map.on('click', function(e) {
                document.getElementById('latitude').value = e.latlng.lat.toFixed(6);
                document.getElementById('longitude').value = e.latlng.lng.toFixed(6);
                if (marker) marker.setLatLng(e.latlng);
                else marker = L.marker(e.latlng).addTo(map);
                reverseGeocode(e.latlng.lat, e.latlng.lng);
            });
        }

        function reverseGeocode(lat, lng) {
            fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}`)
                .then(res => res.json())
                .then(data => { if (data.display_name) document.getElementById('addressInput').value = data.display_name; });
        }

        document.getElementById('addressInput').addEventListener('blur', function() {
            let address = this.value;
            if (address) {
                fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(address)}`)
                    .then(res => res.json())
                    .then(data => {
                        if (data && data.length) {
                            let lat = data[0].lat, lng = data[0].lon;
                            document.getElementById('latitude').value = lat;
                            document.getElementById('longitude').value = lng;
                            map.setView([lat, lng], 15);
                            if (marker) marker.setLatLng([lat, lng]);
                            else marker = L.marker([lat, lng]).addTo(map);
                        }
                    });
            }
        });

        document.getElementById('isFreeCheckbox').addEventListener('change', function() {
            let priceField = document.getElementById('priceField');
            let priceInput = document.querySelector('#Price');
            if (this.checked) {
                priceField.style.display = 'none';
                priceInput.value = 0;
            } else {
                priceField.style.display = 'block';
            }
        });

        initMap();
    </script>
}