@model EventHub.Models.Event

@{
    ViewData["Title"] = "Delete Event - EventHub";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .delete-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem;
    }

    .delete-card {
        background: rgba(26, 26, 46, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        border: 1px solid rgba(220, 53, 69, 0.3);
        overflow: hidden;
    }

    .delete-header {
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        padding: 1.5rem;
        text-align: center;
    }

    .delete-body {
        padding: 2rem;
    }

    .warning-icon {
        font-size: 4rem;
        color: #dc3545;
        margin-bottom: 1rem;
    }

    .event-details {
        background: rgba(220, 53, 69, 0.1);
        border-radius: 15px;
        padding: 1.5rem;
        margin: 1.5rem 0;
    }

    .detail-row {
        display: flex;
        padding: 8px 0;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .detail-label {
        width: 120px;
        color: #00d2ff;
        font-weight: 500;
    }

    .detail-value {
        flex: 1;
        color: white;
    }

    .btn-delete {
        background: #dc3545;
        color: white;
        padding: 12px 30px;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s ease;
        border: none;
    }

        .btn-delete:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(220, 53, 69, 0.4);
        }

    .btn-cancel {
        background: transparent;
        border: 2px solid rgba(0, 210, 255, 0.5);
        color: #00d2ff;
        padding: 10px 30px;
        border-radius: 10px;
        transition: all 0.3s ease;
    }

    .warning-text {
        color: #ff6666;
        font-weight: 500;
    }
</style>

<div class="container delete-container">
    <div class="delete-card">
        <div class="delete-header">
            <h2 class="text-white mb-0">
                <i class="bi bi-trash"></i> Delete Event
            </h2>
            <p class="text-white opacity-75 mt-2">This action cannot be undone</p>
        </div>

        <div class="delete-body">
            <div class="text-center">
                <div class="warning-icon">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
                <h4 class="text-white">Are you sure you want to delete this event?</h4>
                <p class="text-muted">This will permanently remove the event and all registrations.</p>
            </div>

            <div class="event-details">
                <div class="detail-row">
                    <div class="detail-label">Event Name:</div>
                    <div class="detail-value">@Model.Name</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Date & Time:</div>
                    <div class="detail-value">@Model.DateTime.ToString("MMMM dd, yyyy - h:mm tt")</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Location:</div>
                    <div class="detail-value">@Model.Location</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Category:</div>
                    <div class="detail-value">@Model.Category</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Capacity:</div>
                    <div class="detail-value">@Model.Capacity spots</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Registered:</div>
                    <div class="detail-value warning-text">@(Model.Registrations?.Count ?? 0) people registered</div>
                </div>
            </div>

            <div class="d-flex justify-content-center gap-3">
                <form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-delete">
                        <i class="bi bi-trash"></i> Yes, Delete Event
                    </button>
                </form>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn-cancel">
                    <i class="bi bi-x-lg"></i> No, Go Back
                </a>
            </div>
        </div>
    </div>
</div>