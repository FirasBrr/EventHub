@model EventHub.Models.Event

@{
    ViewData["Title"] = "Create Event - EventHub";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .form-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 32px 20px;
    }

    .form-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
    }

    .form-header {
        background: linear-gradient(135deg, var(--accent-blue) 0%, #2563eb 100%);
        padding: 28px 24px;
        text-align: center;
    }

        .form-header h2 {
            font-family: 'Syne', sans-serif;
            font-size: 1.6rem;
            font-weight: 800;
            color: white;
            margin-bottom: 6px;
        }

    .form-body {
        padding: 28px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--text-md);
        margin-bottom: 8px;
        display: block;
    }

        .form-label i {
            color: var(--accent-blue);
            margin-right: 6px;
        }

    .form-control, .form-select {
        width: 100%;
        padding: 10px 14px;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        color: var(--text-hi);
        font-size: 0.875rem;
        transition: all 0.2s;
    }

        .form-control:focus, .form-select:focus {
            outline: none;
            border-color: var(--accent-blue);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
        }

    textarea.form-control {
        resize: vertical;
        min-height: 100px;
    }

    .row {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
    }

        .row > div {
            flex: 1;
            min-width: 200px;
        }

    #map {
        height: 320px;
        border-radius: var(--radius-sm);
        border: 1px solid var(--border);
        overflow: hidden;
        margin-top: 8px;
    }

    .checkbox-group {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 8px;
    }

        .checkbox-group input {
            width: 18px;
            height: 18px;
            accent-color: var(--accent-blue);
            margin: 0;
        }

    .info-tip {
        background: rgba(59, 130, 246, 0.08);
        border-left: 3px solid var(--accent-blue);
        padding: 12px 16px;
        border-radius: var(--radius-sm);
        margin-top: 20px;
        font-size: 0.8rem;
        color: var(--text-md);
    }

    .btn-submit {
        background: var(--accent-blue);
        color: white;
        border: none;
        padding: 12px 28px;
        border-radius: var(--radius-sm);
        font-weight: 600;
        font-size: 0.875rem;
        cursor: pointer;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-submit:hover {
            background: #2563eb;
            transform: translateY(-1px);
        }

    .btn-cancel {
        background: transparent;
        border: 1px solid var(--border);
        color: var(--text-md);
        padding: 11px 28px;
        border-radius: var(--radius-sm);
        font-weight: 500;
        text-decoration: none;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-cancel:hover {
            border-color: var(--accent-red);
            color: var(--accent-red);
        }

    .validation-summary {
        background: rgba(239, 68, 68, 0.08);
        border-left: 3px solid var(--accent-red);
        padding: 12px 16px;
        border-radius: var(--radius-sm);
        margin-bottom: 24px;
        font-size: 0.85rem;
        color: var(--accent-red);
    }
</style>

<div class="form-container">
    <div class="form-card">
        <div class="form-header">
            <h2><i class="bi bi-plus-circle"></i> Create new event</h2>
            <p style="color: rgba(255,255,255,0.8); font-size: 0.85rem;">Fill in the details below</p>
        </div>

        <div class="form-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                <div class="form-group">
                    <label asp-for="Name" class="form-label"><i class="bi bi-tag"></i> Event name</label>
                    <input asp-for="Name" class="form-control" placeholder="e.g., Tech Conference 2024" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Description" class="form-label"><i class="bi bi-file-text"></i> Description</label>
                    <textarea asp-for="Description" class="form-control" placeholder="Describe your event..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div>
                        <label asp-for="DateTime" class="form-label"><i class="bi bi-calendar"></i> Date & time</label>
                        <input asp-for="DateTime" class="form-control" type="datetime-local" />
                        <span asp-validation-for="DateTime" class="text-danger small"></span>
                    </div>
                    <div>
                        <label asp-for="Category" class="form-label"><i class="bi bi-grid"></i> Category</label>
                        <select asp-for="Category" class="form-select">
                            <option value="Conference">Conference</option>
                            <option value="Workshop">Workshop</option>
                            <option value="Music">Music</option>
                            <option value="Networking">Networking</option>
                            <option value="Sports">Sports</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label"><i class="bi bi-geo-alt"></i> Location</label>
                    <input asp-for="FullAddress" id="addressInput" class="form-control" placeholder="Full address" />
                </div>

                <div class="row">
                    <div>
                        <label asp-for="Latitude" class="form-label"><i class="bi bi-arrow-up"></i> Latitude</label>
                        <input asp-for="Latitude" id="latitude" class="form-control" readonly />
                    </div>
                    <div>
                        <label asp-for="Longitude" class="form-label"><i class="bi bi-arrow-right"></i> Longitude</label>
                        <input asp-for="Longitude" id="longitude" class="form-control" readonly />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label"><i class="bi bi-map"></i> Click on map to set location</label>
                    <div id="map"></div>
                </div>

                <div class="row">
                    <div>
                        <label asp-for="Location" class="form-label"><i class="bi bi-building"></i> Venue name</label>
                        <input asp-for="Location" class="form-control" placeholder="e.g., Convention Center" />
                        <span asp-validation-for="Location" class="text-danger small"></span>
                    </div>
                    <div>
                        <label asp-for="Capacity" class="form-label"><i class="bi bi-people"></i> Capacity</label>
                        <input asp-for="Capacity" class="form-control" placeholder="Maximum attendees" />
                        <span asp-validation-for="Capacity" class="text-danger small"></span>
                    </div>
                </div>

                <div class="checkbox-group">
                    <input asp-for="IsFree" class="form-check-input" id="isFreeCheckbox" />
                    <label asp-for="IsFree">This is a free event</label>
                </div>

                <div class="form-group" id="priceField">
                    <label asp-for="Price" class="form-label"><i class="bi bi-currency-dollar"></i> Ticket price</label>
                    <input asp-for="Price" class="form-control" placeholder="0.00" />
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>

                <div class="info-tip">
                    <i class="bi bi-info-circle"></i> <strong>Tip:</strong> Enter an address and press Tab, or click directly on the map to set the event location.
                </div>

                <div style="display: flex; gap: 12px; margin-top: 28px;">
                    <button type="submit" class="btn-submit"><i class="bi bi-check-lg"></i> Create event</button>
                    <a asp-action="Index" class="btn-cancel"><i class="bi bi-x-lg"></i> Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        var map, marker;

        function initMap() {
            map = L.map('map').setView([40.7128, -74.0060], 13);
            L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; OpenStreetMap'
            }).addTo(map);

            map.on('click', function(e) {
                document.getElementById('latitude').value = e.latlng.lat.toFixed(6);
                document.getElementById('longitude').value = e.latlng.lng.toFixed(6);
                if (marker) marker.setLatLng(e.latlng);
                else marker = L.marker(e.latlng).addTo(map);
                reverseGeocode(e.latlng.lat, e.latlng.lng);
            });
        }

        function reverseGeocode(lat, lng) {
            fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}`)
                .then(res => res.json())
                .then(data => { if (data.display_name) document.getElementById('addressInput').value = data.display_name; })
                .catch(e => console.log(e));
        }

        document.getElementById('addressInput').addEventListener('blur', function() {
            let address = this.value;
            if (address) {
                fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(address)}`)
                    .then(res => res.json())
                    .then(data => {
                        if (data && data.length) {
                            let lat = data[0].lat, lng = data[0].lon;
                            document.getElementById('latitude').value = lat;
                            document.getElementById('longitude').value = lng;
                            map.setView([lat, lng], 15);
                            if (marker) marker.setLatLng([lat, lng]);
                            else marker = L.marker([lat, lng]).addTo(map);
                        }
                    });
            }
        });

        document.getElementById('isFreeCheckbox').addEventListener('change', function() {
            document.getElementById('priceField').style.display = this.checked ? 'none' : 'block';
            if (this.checked) document.querySelector('#Price').value = 0;
        });

        initMap();
    </script>
}