@using System.Security.Claims
@model EventHub.Models.Event

@{
    ViewData["Title"] = $"{Model.Name} - EventHub";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .details-container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 32px 20px;
    }

    .hero-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        margin-bottom: 28px;
    }

    .hero-banner {
        height: 200px;
        background: linear-gradient(135deg, var(--accent-blue) 0%, #2563eb 100%);
        position: relative;
    }

    .status-badge {
        position: absolute;
        top: 20px;
        right: 20px;
        padding: 6px 16px;
        border-radius: 40px;
        font-size: 0.75rem;
        font-weight: 600;
        color: white;
    }

    .hero-content {
        padding: 24px 28px;
    }

    .category-tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(59, 130, 246, 0.1);
        color: var(--accent-blue);
        padding: 4px 12px;
        border-radius: 40px;
        font-size: 0.7rem;
        font-weight: 600;
        margin-bottom: 14px;
    }

    .info-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 20px;
        margin-bottom: 20px;
    }

        .info-card h4 {
            font-family: 'Syne', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            margin-bottom: 14px;
            padding-bottom: 10px;
            border-bottom: 1px solid var(--border);
        }

    #fullMap {
        height: 280px;
        border-radius: var(--radius-sm);
        overflow: hidden;
        margin-top: 12px;
    }

    .registration-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 24px;
        position: sticky;
        top: 100px;
    }

    .price-large {
        font-family: 'Syne', sans-serif;
        font-size: 2rem;
        font-weight: 800;
        text-align: center;
        margin-bottom: 20px;
    }

        .price-large.free {
            color: #10b981;
        }

    .detail-row {
        display: flex;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px solid var(--border);
    }

    .capacity-bar {
        background: var(--bg);
        border-radius: 10px;
        height: 6px;
        margin: 8px 0;
        overflow: hidden;
    }

    .capacity-fill {
        background: var(--accent-blue);
        height: 100%;
        border-radius: 10px;
    }

    .btn-primary-full {
        background: var(--accent-blue);
        color: white;
        border: none;
        padding: 12px;
        border-radius: var(--radius-sm);
        font-weight: 600;
        width: 100%;
        transition: all 0.2s;
    }

        .btn-primary-full:hover {
            background: #2563eb;
        }

    .btn-danger-full {
        background: var(--accent-red);
        color: white;
        border: none;
        padding: 12px;
        border-radius: var(--radius-sm);
        font-weight: 600;
        width: 100%;
        margin-top: 10px;
    }

    .admin-actions {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
    }

        .admin-actions a {
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 0.75rem;
            text-decoration: none;
        }
</style>

<div class="details-container">
    <div class="hero-card">
        <div class="hero-banner">
            <div class="status-badge" style="background: @(Model.IsFree ? "#10b981" : "var(--accent-blue)")">
                @(Model.IsFree ? "Free event" : "Paid event")
            </div>
        </div>
        <div class="hero-content">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                <div>
                    <span class="category-tag"><i class="bi bi-tag"></i> @Model.Category</span>
                    <h1 style="font-family: 'Syne', sans-serif; font-size: 1.8rem; font-weight: 800; margin: 8px 0 4px;">@Model.Name</h1>
                    <p class="text-muted small">Created @Model.CreatedAt.ToString("MMMM dd, yyyy")</p>
                </div>
                @if (User.IsInRole("Admin"))
                {
                    <div class="admin-actions">
                        <a asp-action="Edit" asp-route-id="@Model.Id" style="background: #fef3c7; color: #d97706;">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" style="background: #fee2e2; color: #dc2626;">
                            <i class="bi bi-trash"></i> Delete
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="info-card">
                <h4><i class="bi bi-file-text" style="color: var(--accent-blue);"></i> About this event</h4>
                <p style="color: var(--text-md); line-height: 1.7;">@Model.Description</p>
            </div>

            <div class="info-card">
                <h4><i class="bi bi-geo-alt" style="color: var(--accent-blue);"></i> Location</h4>
                <p><strong>Venue:</strong> @Model.Location</p>
                @if (!string.IsNullOrEmpty(Model.FullAddress))
                {
                    <p class="text-muted small"><i class="bi bi-pin-map"></i> @Model.FullAddress</p>
                }
                <div id="fullMap"></div>
            </div>

            @if (Model.Registrations != null && Model.Registrations.Any())
            {
                <div class="info-card">
                    <h4><i class="bi bi-people" style="color: var(--accent-blue);"></i> Attendees (@Model.Registrations.Count)</h4>
                    @foreach (var reg in Model.Registrations.Take(8))
                    {
                        <div class="d-flex align-items-center gap-2 py-2 border-bottom">
                            <i class="bi bi-person-circle" style="color: var(--accent-blue);"></i>
                            <span class="small">Attendee</span>
                            <span class="small text-muted ms-auto">@reg.RegisteredAt.ToString("MMM dd")</span>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="col-lg-5">
            <div class="registration-card">
                <div class="price-large @(Model.IsFree ? "free" : "")">
                    @(Model.IsFree ? "FREE" : Model.Price.ToString("C"))
                </div>

                <div class="detail-row">
                    <span><i class="bi bi-calendar"></i> Date</span>
                    <span class="fw-semibold">@Model.DateTime.ToString("MMM dd, yyyy • h:mm tt")</span>
                </div>

                <div class="detail-row">
                    <span><i class="bi bi-people"></i> Capacity</span>
                    <span>@(Model.Registrations?.Count ?? 0) / @Model.Capacity</span>
                </div>
                <div class="capacity-bar">
                    <div class="capacity-fill" style="width: @(Model.Registrations != null && Model.Capacity > 0 ? (double)Model.Registrations.Count / Model.Capacity * 100 : 0)%"></div>
                </div>

                @if (User.IsInRole("Admin"))
                {
                    <div class="text-center mt-3">
                        <span class="badge" style="background: #fef3c7; color: #d97706; padding: 6px 12px;">
                            <i class="bi bi-shield-check"></i> Admin view
                        </span>
                        <p class="small text-muted mt-2">Administrators manage events, not register for them.</p>
                    </div>
                }
                else if (User.Identity?.IsAuthenticated == true)
                {
                    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
                    var isRegistered = Model.Registrations?.Any(r => r.UserId == userId) ?? false;

                    if (isRegistered)
                    {
                        <button class="btn-primary-full" disabled style="background: #10b981;">
                            <i class="bi bi-check-circle"></i> You're registered
                        </button>
                        <form asp-action="CancelRegistration" asp-route-id="@Model.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-danger-full" onclick="return confirm('Cancel your registration?')">
                                <i class="bi bi-x-circle"></i> Cancel registration
                            </button>
                        </form>
                    }
                    else if ((Model.Registrations?.Count ?? 0) >= Model.Capacity)
                    {
                        <button class="btn-primary-full" disabled style="background: #94a3b8;">
                            <i class="bi bi-x-circle"></i> Event is full
                        </button>
                    }
                    else
                    {
                        <form asp-action="Register" asp-route-id="@Model.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-primary-full">
                                <i class="bi bi-ticket-perforated"></i> Register now
                            </button>
                        </form>
                    }
                }
                else
                {
                    <a href="/Account/Login" class="btn-primary-full text-center" style="text-decoration: none;">
                        <i class="bi bi-box-arrow-in-right"></i> Sign in to register
                    </a>
                    <p class="text-center small text-muted mt-2">New here? <a href="/Account/Register" style="color: var(--accent-blue);">Create account</a></p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        var map = L.map('fullMap');
        @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
        {
                <text>
                map.setView([@Model.Latitude, @Model.Longitude], 14);
                L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
                    attribution: '&copy; OpenStreetMap'
                }).addTo(map);
                L.marker([@Model.Latitude, @Model.Longitude]).addTo(map).bindPopup('@Model.Name').openPopup();
                </text>
        }
        else
        {
                <text>
                map.setView([40.7128, -74.0060], 12);
                L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
                    attribution: '&copy; OpenStreetMap'
                }).addTo(map);
                </text>
        }
    </script>
}